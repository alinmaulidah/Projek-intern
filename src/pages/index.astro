<!-- ==================================================================== -->
<!-- CLIENT-SIDE SCRIPTS                                                  -->
<!-- ==================================================================== -->
<script>
  // ====================================================================
  // DATA
  // ====================================================================
  const heroSlidesData = [
    { label: "Laboratorium Modern", subtitle: "Formulasi presisi dengan teknologi terkini" },
    { label: "Produksi Berkualitas", subtitle: "Standar CPKB & GMP terjaga ketat" },
    { label: "Siap Dikemas & Kirim", subtitle: "Produk jadi langsung siap distribusi" },
    { label: "Riset & Inovasi", subtitle: "500+ formula siap dikustomisasi" },
  ];

  const processStepsData = [
    { step: 1, title: "Konsultasi Konsep", icon: "lucide:message-circle", desc: "Diskusikan ide produk, konsep, dan target pasar secara gratis bersama tim konsultan kami." },
    { step: 2, title: "Riset & Formulasi", icon: "lucide:flask-conical", desc: "Tim R&D melakukan riset dan mengembangkan formula custom sesuai kebutuhan brand Anda." },
    { step: 3, title: "Pembuatan Sample", icon: "lucide:beaker", desc: "Sample produk dibuat untuk Anda evaluasi sebelum masuk ke tahap produksi massal." },
    { step: 4, title: "Revisi Sample", icon: "lucide:refresh-cw", desc: "Revisi sample hingga sesuai dengan ekspektasi dan standar kualitas brand Anda." },
    { step: 5, title: "Desain & Legalitas", icon: "lucide:file-text", desc: "Desain kemasan, pengurusan BPOM, Halal, dan HKI — semua kami bantu urus." },
  ];

  // ====================================================================
  // 1. HERO SLIDER
  // ====================================================================
  let heroIdx = 0;
  const heroTotal = heroSlidesData.length;
  let heroTimer: ReturnType<typeof setInterval> | undefined;

  function goHero(idx: number) {
    heroIdx = idx;
    document.querySelectorAll<HTMLElement>(".hero-slide").forEach((s, i) => {
      s.style.opacity = i === idx ? "1" : "0";
    });
    document.querySelectorAll<HTMLElement>(".hero-dot").forEach((d, i) => {
      if (i === idx) { d.className = "hero-dot h-1.5 w-8 rounded-full bg-white transition-all duration-500"; }
      else { d.className = "hero-dot h-1.5 w-1.5 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-500"; }
    });
  }

  function startHero() { stopHero(); heroTimer = setInterval(() => goHero((heroIdx + 1) % heroTotal), 5000); }
  function stopHero() { if (heroTimer) clearInterval(heroTimer); }

  document.querySelectorAll<HTMLElement>(".hero-dot").forEach((dot) => {
    dot.addEventListener("click", () => {
      const idx = parseInt(dot.getAttribute("data-slide") || "0");
      goHero(idx);
      startHero();
    });
  });

  startHero();

  // ====================================================================
  // 2. STATS COUNTER (Intersection Observer)
  // ====================================================================
  const statCounters = document.querySelectorAll<HTMLElement>(".stat-counter");
  let countersAnimated = false;

  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || "0");
    const duration = 2000;
    const start = performance.now();
    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target).toString();
      if (progress < 1) requestAnimationFrame(update);
      else el.textContent = target.toString();
    }
    requestAnimationFrame(update);
  }

  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !countersAnimated) {
        countersAnimated = true;
        statCounters.forEach(c => animateCounter(c));
        statsObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  if (statCounters.length > 0) statsObserver.observe(statCounters[0]);

  // ====================================================================
  // 3. FAQ ACCORDION
  // ====================================================================
  document.querySelectorAll<HTMLElement>(".faq-trigger").forEach(trigger => {
    trigger.addEventListener("click", () => {
      const panel = trigger.nextElementSibling as HTMLElement;
      const icon = trigger.querySelector(".faq-icon") as HTMLElement;
      const isOpen = trigger.getAttribute("aria-expanded") === "true";
      // Close all
      document.querySelectorAll<HTMLElement>(".faq-trigger").forEach(t => {
        t.setAttribute("aria-expanded", "false");
        const p = t.nextElementSibling as HTMLElement;
        const i = t.querySelector(".faq-icon") as HTMLElement;
        if (p) { p.style.maxHeight = "0"; p.style.opacity = "0"; }
        if (i) i.style.transform = "rotate(0deg)";
      });
      if (!isOpen) {
        trigger.setAttribute("aria-expanded", "true");
        if (panel) { panel.style.maxHeight = panel.scrollHeight + "px"; panel.style.opacity = "1"; }
        if (icon) icon.style.transform = "rotate(180deg)";
      }
    });
  });

  // ====================================================================
  // 4. PROCESS — Desktop Interactive Timeline
  // ====================================================================
  const processLen = processStepsData.length;
  let activeProcess = 0;
  let processTimer: ReturnType<typeof setInterval> | undefined;

  function goProcess(idx: number) {
    if (idx < 0 || idx >= processLen || idx === activeProcess) return;
    activeProcess = idx;
    const step = processStepsData[idx];

    document.querySelectorAll<HTMLElement>(".process-img").forEach((img, i) => {
      if (i === idx) { img.classList.add("opacity-100", "scale-100"); img.classList.remove("opacity-0", "scale-110"); }
      else { img.classList.remove("opacity-100", "scale-100"); img.classList.add("opacity-0", "scale-110"); }
    });

    const labelEl = document.getElementById("process-step-label");
    const titleEl = document.getElementById("process-step-title");
    const iconEl = document.getElementById("process-slide-icon");
    if (labelEl) labelEl.textContent = `Tahap ${step.step}`;
    if (titleEl) titleEl.textContent = step.title;
    if (iconEl) iconEl.setAttribute("name", step.icon);

    document.querySelectorAll<HTMLElement>(".process-btn").forEach((btn, i) => {
      btn.classList.remove("border-primary/30", "bg-primary/[0.04]", "shadow-md", "border-base-200/70", "bg-white", "shadow-sm");
      if (i === idx) {
        btn.classList.add("border-primary/30", "bg-primary/[0.04]", "shadow-md");
      } else {
        btn.classList.add("border-base-200/70", "bg-white", "shadow-sm");
      }
    });
  }

  function startProcessAuto() { stopProcessAuto(); processTimer = setInterval(() => goProcess((activeProcess + 1) % processLen), 4000); }
  function stopProcessAuto() { if (processTimer) { clearInterval(processTimer); processTimer = undefined; } }

  document.querySelectorAll<HTMLElement>(".process-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      goProcess(parseInt(btn.getAttribute("data-step") || "0"));
      startProcessAuto();
    });
  });

  const processContainer = document.querySelector(".lg\\:flex");
  if (processContainer) {
    processContainer.addEventListener("mouseenter", stopProcessAuto);
    processContainer.addEventListener("mouseleave", startProcessAuto);
    startProcessAuto();
  }

  // ====================================================================
  // 5. MOBILE PROCESS CAROUSEL
  // ====================================================================
  let mobileIdx = 0;
  const mobileTotal = processStepsData.length;
  const mobileTrack = document.getElementById("mobile-track");
  const mobileDots = document.querySelectorAll<HTMLElement>(".mobile-dot");
  const mobileProgress = document.getElementById("mobile-progress");
  const mobileCurrent = document.getElementById("mobile-current");
  const mobileTitle = document.getElementById("mobile-title");
  const mobileSlideIcon = document.getElementById("mobile-slide-icon");
  let mobileTimer: ReturnType<typeof setInterval> | undefined;

  function goMobile(idx: number) {
    if (!mobileTrack) return;
    mobileIdx = ((idx % mobileTotal) + mobileTotal) % mobileTotal;
    mobileTrack.style.transform = `translateX(-${mobileIdx * 100}%)`;
    if (mobileProgress) mobileProgress.style.width = `${((mobileIdx + 1) / mobileTotal) * 100}%`;
    if (mobileCurrent) mobileCurrent.textContent = String(mobileIdx + 1);
    if (mobileTitle && processStepsData[mobileIdx]) mobileTitle.textContent = processStepsData[mobileIdx].title;
    if (mobileSlideIcon && processStepsData[mobileIdx]) mobileSlideIcon.setAttribute("name", processStepsData[mobileIdx].icon);

    document.querySelectorAll<HTMLElement>(`[id^="mobile-img-"]`).forEach((img, i) => {
      if (i === mobileIdx) { img.classList.add("opacity-100", "scale-100"); img.classList.remove("opacity-0", "scale-110"); }
      else { img.classList.remove("opacity-100", "scale-100"); img.classList.add("opacity-0", "scale-110"); }
    });

    mobileDots.forEach((dot, i) => {
      if (i === mobileIdx) { dot.className = "mobile-dot h-1.5 w-6 rounded-full bg-primary transition-all duration-400"; }
      else { dot.className = "mobile-dot h-1.5 w-1.5 rounded-full bg-base-300 transition-all duration-400"; }
    });
  }

  function startMobile() { stopMobile(); mobileTimer = setInterval(() => goMobile(mobileIdx + 1), 4000); }
  function stopMobile() { if (mobileTimer) clearInterval(mobileTimer); }
  function resetMobile() { stopMobile(); startMobile(); }

  document.getElementById("mobile-prev")?.addEventListener("click", () => { goMobile(mobileIdx - 1); resetMobile(); });
  document.getElementById("mobile-next")?.addEventListener("click", () => { goMobile(mobileIdx + 1); resetMobile(); });
  mobileDots.forEach((dot, i) => { dot.addEventListener("click", () => { goMobile(i); resetMobile(); }); });

  let mTouchX = 0;
  mobileTrack?.parentElement?.addEventListener("touchstart", (e) => { mTouchX = e.changedTouches[0].screenX; stopMobile(); }, { passive: true });
  mobileTrack?.parentElement?.addEventListener("touchend", (e) => {
    const diff = mTouchX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 40) goMobile(diff > 0 ? mobileIdx + 1 : mobileIdx - 1);
    resetMobile();
  }, { passive: true });

  startMobile();

  // ====================================================================
  // 6. TESTIMONIAL CAROUSEL
  // ====================================================================
  const testiTrack = document.getElementById("testi-track");
  const testiSlides = document.querySelectorAll<HTMLElement>(".testi-slide");
  const testiDots = document.querySelectorAll<HTMLElement>(".testi-dot");
  let testiIdx = 0;
  const testiTotal = testiSlides.length;
  let testiTimer: ReturnType<typeof setInterval> | undefined;

  function updateTesti() {
    if (!testiTrack) return;
    testiTrack.style.transform = `translateX(-${testiIdx * 100}%)`;
    testiDots.forEach((d, i) => {
      if (i === testiIdx) { d.className = "testi-dot h-2 w-7 rounded-full bg-primary transition-all duration-400"; }
      else { d.className = "testi-dot h-2 w-2 rounded-full bg-base-300 transition-all duration-400"; }
    });
  }

  function startTesti() { stopTesti(); testiTimer = setInterval(() => { testiIdx = (testiIdx + 1) % testiTotal; updateTesti(); }, 4000); }
  function stopTesti() { if (testiTimer) clearInterval(testiTimer); }
  function resetTesti() { stopTesti(); startTesti(); }

  document.getElementById("testi-prev")?.addEventListener("click", () => { testiIdx = (testiIdx - 1 + testiTotal) % testiTotal; updateTesti(); resetTesti(); });
  document.getElementById("testi-next")?.addEventListener("click", () => { testiIdx = (testiIdx + 1) % testiTotal; updateTesti(); resetTesti(); });
  testiDots.forEach(d => { d.addEventListener("click", () => { testiIdx = parseInt(d.dataset.idx || "0"); updateTesti(); resetTesti(); }); });

  startTesti();
</script>

