---
import Icon from "../components/ui/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { advantages } from "../data/advantages";
import { factoryStats } from "../data/factory";
import { services } from "../data/services";
import { processSteps } from "../data/process";
import { testimonials } from "../data/testimonials";
import { heroImages, processImages } from "../data/images";

const processPreviewSteps = processSteps.slice(0, 4);

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

const heroSlides = [
  {
    image: heroImages.skincareHero,
    gradient: "from-emerald-950/85 via-primary/75 to-primary/70",
    badge: "PARTNER MAKLON PROFESIONAL",
    title: "Wujudkan Brand Kecantikan Sendiri",
    desc: "Kami bantu proses maklon dari konsultasi, formulasi, produksi, legalitas, hingga produk siap jual.",
  },
  {
    image: heroImages.formulasiHero,
    gradient: "from-primary/90 via-primary/80 to-emerald-900/85",
    badge: "FORMULA CUSTOM & INOVATIF",
    title: "Riset & Formulasi oleh Tim Ahli",
    desc: "Tim R&D berpengalaman menciptakan formula eksklusif sesuai tren dan kebutuhan brand Anda.",
  },
  {
    image: heroImages.skincareHero,
    gradient: "from-teal-950/85 via-primary/80 to-primary/75",
    badge: "BPOM, HALAL & SIAP JUAL",
    title: "Legalitas Lengkap, Produk Siap Dipasarkan",
    desc: "BPOM, Halal, HKI — semua diurus. Anda tinggal fokus jualan.",
  },
];
---

<MainLayout
  title="Aquila Maklon – Jasa Maklon Skincare & Kosmetik Terpercaya"
  description={siteConfig.description}
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. HERO — Full height slider                                      -->
    <!-- ================================================================== -->
    <section id="hero" class="relative flex min-h-[80vh] items-center overflow-hidden">
      {heroSlides.map((slide, idx) => (
        <div
          id={`hero-slide-bg-${idx}`}
          class="hero-bg-slide absolute inset-0 z-0 bg-cover bg-center transition-all duration-1000 ease-in-out"
          class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-105": idx !== 0 }}
          style={`background-image: url('${slide.image}');`}
        >
          <div class={`absolute inset-0 bg-gradient-to-br ${slide.gradient}`}></div>
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
        </div>
      ))}

      <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-20 lg:px-8">
        <div class="max-w-3xl">
          <div class="mb-4 inline-flex min-w-0 items-center justify-center gap-2 rounded-full border border-white/10 bg-white/[0.06] px-5 py-1.5 backdrop-blur-xl">
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-300"></span>
            <span id="hero-badge" class="text-xs font-semibold tracking-[0.15em] text-white/80">{heroSlides[0].badge}</span>
          </div>
          <h1 id="hero-title" class="text-3xl font-bold leading-tight text-white md:text-5xl lg:text-6xl xl:text-7xl">
            {heroSlides[0].title}
          </h1>
          <p id="hero-desc" class="mt-4 max-w-2xl text-sm leading-relaxed text-white/65 md:text-base lg:text-lg">
            {heroSlides[0].desc}
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href={waLink} target="_blank" rel="noopener noreferrer"
              class="group inline-flex h-12 items-center gap-2.5 rounded-full bg-white px-8 text-sm font-semibold text-primary shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl">
              <Icon name="mdi:whatsapp" class="h-4 w-4" />
              Konsultasi via WhatsApp
            </a>
            <a href="/alur-maklon"
              class="group inline-flex h-12 items-center gap-1.5 rounded-full border border-white/20 bg-white/[0.06] px-8 text-sm font-medium text-white backdrop-blur-xl transition-all duration-300 hover:border-white/40 hover:bg-white/[0.12]">
              Lihat Alur Maklon
              <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" />
            </a>
          </div>

          <!-- Trust badges row -->
          <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2">
            <span class="inline-flex items-center gap-1.5 text-xs text-white/40">
              <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-emerald-300/60" /> BPOM Terdaftar
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-white/40">
              <Icon name="lucide:award" class="h-3.5 w-3.5 text-emerald-300/60" /> Sertifikat Halal
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-white/40">
              <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-emerald-300/60" /> CPKB Standard
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-white/40">
              <Icon name="lucide:award" class="h-3.5 w-3.5 text-emerald-300/60" /> ISO 9001:2015
            </span>
          </div>
        </div>
      </div>

      <!-- Slide dots -->
      <div class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-2">
        {heroSlides.map((_, idx) => (
          <button
            id={`hero-dot-${idx}`}
            class={`hero-dot rounded-full transition-all duration-500 ${idx === 0 ? "h-2 w-8 bg-white" : "h-2 w-2 bg-white/30"}`}
            aria-label={`Slide ${idx + 1}`}
          ></button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. LAYANAN                                                        -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-4 py-1 text-[11px] font-semibold tracking-[0.12em] text-primary">
            LAYANAN MAKLON
          </span>
          <h2 class="mt-3 text-3xl font-bold md:text-4xl">Solusi Lengkap untuk Brand Kecantikan Anda</h2>
          <p class="mt-3 text-sm text-base-content/55">Konsultasi gratis, proses transparan, hasil maksimal.</p>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((svc) => {
            const waService = createWhatsappLink(siteConfig.waNumber, `Halo, saya ingin konsultasi maklon ${svc.title}.`);
            return (
              <div class="group relative overflow-hidden rounded-2xl border border-base-200/80 bg-base-100 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl transition-transform duration-300 group-hover:scale-110"><Icon name={svc.icon} size={24} /></div>
                <h3 class="text-base font-bold transition-colors duration-300 group-hover:text-primary">{svc.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-base-content/55 line-clamp-2">{svc.desc}</p>
                <a href={waService} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-primary opacity-0 transition-all duration-300 group-hover:opacity-100">
                  Konsultasi <Icon name="lucide:arrow-right" class="h-3 w-3" />
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. STATISTIK                                                       -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-primary py-16 md:py-20">
      <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 50px 50px;"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mb-10 text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-1 text-[11px] font-semibold tracking-[0.12em] text-white">OUR NUMBERS</span>
          <h2 class="mt-3 text-3xl font-bold text-white md:text-4xl">Aquila Maklon dalam Angka</h2>
        </div>
        <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
          {factoryStats.map((stat) => (
            <div class="text-center">
              <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-2xl border border-white/20 bg-white/15 shadow-sm backdrop-blur-md transition-all duration-500 hover:scale-110 hover:bg-white/25 hover:shadow-lg">
                <span class="text-3xl font-black text-white">{stat.value}</span>
              </div>
              <p class="mt-3 text-sm font-medium text-white/75">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. KEUNGGULAN                                                      -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-4 py-1 text-[11px] font-semibold tracking-[0.12em] text-primary">KEUNGGULAN KAMI</span>
          <h2 class="mt-3 text-3xl font-bold md:text-4xl">Kenapa Aquila Maklon?</h2>
          <p class="mt-3 text-sm text-base-content/55">Setiap detail diperhatikan untuk hasil terbaik.</p>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {advantages.map((adv) => (
            <div class="group relative overflow-hidden rounded-2xl border border-base-200/80 bg-base-100 p-6 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
              <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-xl bg-primary/10 text-3xl transition-transform duration-300 group-hover:scale-110"><Icon name={adv.icon} size={32} /></div>
              <h3 class="mt-4 text-base font-bold transition-colors group-hover:text-primary">{adv.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-base-content/55">{adv.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. PROSES — Interactive Image + Timeline Slider                    -->
    <!-- ================================================================== -->
    <section id="alur-maklon" class="bg-gradient-to-b from-base-100 to-base-200/40 py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <!-- HEADER -->
        <div class="mx-auto max-w-2xl text-center">
          <span class="process-animate inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-4 py-1 text-[11px] font-semibold tracking-[0.12em] text-primary opacity-0">ALUR MAKLON</span>
          <h2 class="process-animate mt-3 text-3xl font-bold md:text-4xl opacity-0 translate-y-4">Proses Mudah & Terarah</h2>
          <p class="process-animate mt-3 text-sm text-base-content/55 opacity-0 translate-y-4">Dari ide ke produk siap jual tanpa hambatan.</p>
        </div>

        <!-- DESKTOP: Interactive Image + Step List -->
        <div class="process-animate relative mt-14 hidden gap-8 opacity-0 translate-y-6 lg:flex">
          <!-- Left: Large Featured Image -->
          <div class="w-[55%] overflow-hidden rounded-2xl shadow-lg">
            <div class="relative aspect-[4/3] bg-base-200">
              {processPreviewSteps.map((step, idx) => (
                <img
                  id={`process-img-${idx}`}
                  class="process-feature-img absolute inset-0 h-full w-full object-cover transition-all duration-700 ease-in-out"
                  class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                  src={processImages[step.imageKey]}
                  alt={step.title}
                  loading={idx === 0 ? "eager" : "lazy"}
                />
              ))}
              <!-- Gradient overlay bottom -->
              <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-black/40 to-transparent"></div>
              <!-- Step badge on image -->
              <div class="absolute bottom-4 left-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20 text-white backdrop-blur-md">
                  <Icon name={processPreviewSteps[0].icon} size={20} />
                </div>
                <div>
                  <span id="desktop-step-label" class="text-xs font-bold tracking-wider text-white/70">TAHAP 1</span>
                  <h3 id="desktop-step-title" class="text-lg font-bold text-white">{processPreviewSteps[0].title}</h3>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Vertical Step List -->
          <div class="flex w-[45%] flex-col justify-center gap-2">
            {processPreviewSteps.map((step, idx) => (
              <button
                class="process-step-btn group flex items-center gap-4 rounded-xl border p-4 text-left transition-all duration-500"
                class:list={{
                  "border-primary/30 bg-primary/[0.04] shadow-md shadow-primary/5": idx === 0,
                  "border-base-200/70 bg-base-100 shadow-sm hover:border-primary/20 hover:bg-primary/[0.02]": idx !== 0,
                }}
                data-step={idx}
                aria-label={`Tahap ${step.step}: ${step.title}`}
              >
                <!-- Icon -->
                <div
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl transition-all duration-500"
                  class:list={{
                    "bg-primary text-white scale-110 shadow-md": idx === 0,
                    "bg-primary/10 text-primary": idx !== 0,
                  }}
                >
                  <Icon name={step.icon} size={20} />
                </div>
                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <span class="text-[11px] font-bold tracking-wider text-primary/60">TAHAP {step.step}</span>
                  <h3 class="text-sm font-bold transition-colors duration-300">{step.title}</h3>
                  <p id={`step-desc-${idx}`} class="mt-0.5 text-xs leading-relaxed text-base-content/55 line-clamp-2">{step.desc}</p>
                </div>
                <!-- Active indicator -->
                <div
                  class="h-2 w-2 shrink-0 rounded-full transition-all duration-500"
                  class:list={{ "bg-primary scale-100": idx === 0, "bg-transparent scale-0": idx !== 0 }}
                ></div>
              </button>
            ))}
          </div>
        </div>

        <!-- MOBILE: Interactive Cards Carousel with Images -->
        <div class="process-animate lg:hidden opacity-0 translate-y-6">
          <div class="relative mt-10">
            <!-- Progress bar -->
            <div class="mb-4 flex items-center gap-2 px-1">
              <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-base-200">
                <div id="mobile-progress" class="h-full w-[25%] rounded-full bg-primary transition-all duration-500 ease-out"></div>
              </div>
              <span class="text-xs font-semibold text-base-content/50">
                <span id="mobile-step-current">1</span>/<span>{processSteps.length}</span>
              </span>
            </div>

            <!-- Image preview -->
            <div class="overflow-hidden rounded-2xl shadow-sm">
              <div class="relative aspect-[16/9] bg-base-200">
                {processPreviewSteps.map((step, idx) => (
                  <img
                    id={`mobile-process-img-${idx}`}
                    class="absolute inset-0 h-full w-full object-cover transition-all duration-600 ease-in-out"
                    class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                    src={processImages[step.imageKey]}
                    alt={step.title}
                    loading={idx === 0 ? "eager" : "lazy"}
                  />
                ))}
                <!-- Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                <div class="absolute bottom-3 left-4 flex items-center gap-2">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/20 text-white backdrop-blur-md">
                    <Icon name={processPreviewSteps[0].icon} size={16} />
                  </div>
                  <span id="mobile-step-title" class="text-sm font-bold text-white">{processPreviewSteps[0].title}</span>
                </div>
              </div>
            </div>

            <!-- Cards track -->
            <div class="mt-3 overflow-hidden rounded-2xl">
              <div id="mobile-carousel-track" class="flex transition-transform duration-500 ease-out">
                {processPreviewSteps.map((step) => (
                  <div class="min-w-0 w-full shrink-0 px-0.5">
                    <div class="rounded-2xl border border-base-200/70 bg-base-100 p-4 shadow-sm">
                      <div class="flex items-center gap-3">
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                          <Icon name={step.icon} size={22} />
                        </div>
                        <div>
                          <span class="text-[11px] font-bold tracking-wider text-primary/60">TAHAP {step.step}</span>
                          <h3 class="text-base font-bold">{step.title}</h3>
                        </div>
                      </div>
                      <p class="mt-2 text-sm leading-relaxed text-base-content/60">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Navigation -->
            <div class="mt-4 flex items-center justify-between">
              <button id="mobile-prev" class="btn btn-circle btn-soft btn-sm" aria-label="Sebelumnya">
                <Icon name="lucide:chevron-left" size={16} />
              </button>

              <div class="flex items-center gap-1.5">
                {processPreviewSteps.map((_, i) => (
                  <button
                    class={`mobile-dot h-1.5 rounded-full transition-all duration-400 ${i === 0 ? "w-6 bg-primary" : "w-1.5 bg-base-300"}`}
                    data-mobile-dot={i}
                    aria-label={`Tahap ${i + 1}`}
                  ></button>
                ))}
              </div>

              <button id="mobile-next" class="btn btn-circle btn-soft btn-sm" aria-label="Selanjutnya">
                <Icon name="lucide:chevron-right" size={16} />
              </button>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="process-animate mt-12 text-center opacity-0 translate-y-4">
          <a href="/alur-maklon" class="group inline-flex h-11 items-center gap-2 rounded-full bg-primary px-8 text-sm font-semibold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:scale-105 hover:shadow-lg">
            Lihat 4 Tahap Lengkap
            <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 6. TESTIMONIAL                                                      -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-4 py-1 text-[11px] font-semibold tracking-[0.12em] text-primary">TESTIMONIAL</span>
          <h2 class="mt-3 text-3xl font-bold md:text-4xl">Dipercaya Brand Partner</h2>
          <p class="mt-3 text-sm text-base-content/55">Mereka sudah merasakan kemudahan bermitra dengan kami.</p>
        </div>

        <div class="mt-10 overflow-hidden">
          <div id="testimonial-track" class="flex gap-4 transition-transform duration-600 ease-in-out">
            {testimonials.map((item) => (
              <div class="testimonial-slide w-full shrink-0 md:w-[calc(50%-8px)] lg:w-[calc(33.333%-11px)]">
                <div class="h-full rounded-2xl border border-base-200/80 bg-base-100 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/15 hover:shadow-md">
                  <Icon name="lucide:quote" class="mb-3 h-6 w-6 text-primary/15" />
                  <p class="text-sm leading-relaxed text-base-content/65 italic">"{item.text}"</p>
                  <div class="mt-4 flex items-center gap-3 border-t border-base-200 pt-4">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{item.name.charAt(0)}</div>
                    <div>
                      <p class="text-sm font-semibold">{item.name}</p>
                      <p class="text-xs text-primary/70">{item.brand}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Carousel controls -->
          <div class="mt-6 flex items-center justify-center gap-3">
            <button id="testi-prev" class="flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100 text-base-content/40 shadow-sm transition-all duration-300 hover:border-primary/30 hover:text-primary" aria-label="Sebelumnya">
              <Icon name="lucide:chevron-left" class="h-3.5 w-3.5" />
            </button>
            {testimonials.map((_, idx) => (
              <button
                id={`testi-dot-${idx}`}
                class={`testi-dot rounded-full transition-all duration-400 ${idx === 0 ? "h-2 w-7 bg-primary" : "h-2 w-2 bg-base-300"}`}
                data-index={idx}
                aria-label={`Testimonial ${idx + 1}`}
              ></button>
            ))}
            <button id="testi-next" class="flex h-9 w-9 items-center justify-center rounded-full border border-base-200 bg-base-100 text-base-content/40 shadow-sm transition-all duration-300 hover:border-primary/30 hover:text-primary" aria-label="Selanjutnya">
              <Icon name="lucide:chevron-right" class="h-3.5 w-3.5" />
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 7. CTA FINAL                                                        -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary to-emerald-900 py-16 md:py-20">
      <div class="pointer-events-none absolute -right-20 -top-20 h-[400px] w-[400px] rounded-full bg-white/[0.03] blur-3xl"></div>
      <div class="relative z-10 mx-auto max-w-3xl px-4 text-center lg:px-8">
        <h2 class="text-3xl font-bold text-white md:text-4xl">Siap Bangun Brand Kamu?</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm text-white/65 md:text-base">Konsultasi gratis sekarang. Tim kami siap bantu dari awal hingga produk siap jual.</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="group inline-flex h-12 items-center gap-2 rounded-full bg-white px-8 text-sm font-semibold text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" class="h-4 w-4" />
            Konsultasi via WhatsApp
          </a>
          <a href="/tentang-kami" class="group inline-flex h-12 items-center gap-2 rounded-full border border-white/20 bg-white/[0.06] px-8 text-sm font-medium text-white backdrop-blur-xl transition-all duration-300 hover:border-white/40 hover:bg-white/[0.12]">
            Tentang Kami
            <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // ====================================================================
  // PROCESS STEPS DATA (inlined for client-side)
  // ====================================================================
  type ProcessImageKey = "konsultasi" | "riset" | "sample" | "revisi" | "desain" | "legalitas" | "produksi" | "qc" | "pengiriman";
  interface ProcessStep {
    step: number;
    title: string;
    icon: string;
    desc: string;
    imageKey: ProcessImageKey;
  }

  const processSteps: ProcessStep[] = [
  { step: 1, title: "Konsultasi Konsep", icon: "lucide:message-circle", desc: "Diskusikan ide produk, konsep, dan target pasar yang diinginkan secara gratis.", imageKey: "konsultasi" },
  { step: 2, title: "Riset & Formulasi", icon: "lucide:flask-conical", desc: "Tim R&D melakukan riset dan mengembangkan formula sesuai kebutuhan dan tren pasar.", imageKey: "riset" },
  { step: 3, title: "Pembuatan Sample", icon: "lucide:beaker", desc: "Sample produk dibuat untuk evaluasi dan persetujuan sebelum produksi massal.", imageKey: "sample" },
  { step: 4, title: "Revisi Sample", icon: "lucide:refresh-cw", desc: "Sample direvisi hingga sesuai dengan keinginan brand Anda.", imageKey: "revisi" },
  ];

  // ====================================================================
  // HERO SLIDER — auto + dots + swipe
  // ====================================================================
  const heroData = [
    { badge: "PARTNER MAKLON PROFESIONAL", title: "Wujudkan Brand Kecantikan Sendiri", desc: "Kami bantu proses maklon dari konsultasi, formulasi, produksi, legalitas, hingga produk siap jual." },
    { badge: "FORMULA CUSTOM & INOVATIF", title: "Riset & Formulasi oleh Tim Ahli", desc: "Tim R&D berpengalaman menciptakan formula eksklusif sesuai tren dan kebutuhan brand Anda." },
    { badge: "BPOM, HALAL & SIAP JUAL", title: "Legalitas Lengkap, Produk Siap Dipasarkan", desc: "BPOM, Halal, HKI — semua diurus. Anda tinggal fokus jualan." },
  ];

  let currentHero = 0;
  const totalHero = heroData.length;
  let heroInterval: ReturnType<typeof setInterval> | undefined;

  function goHero(idx: number) {
    currentHero = idx;
    const d = heroData[idx];

    for (let i = 0; i < totalHero; i++) {
      const bg = document.getElementById(`hero-slide-bg-${i}`);
      if (!bg) continue;
      if (i === idx) { bg.classList.add("opacity-100"); bg.classList.remove("opacity-0", "scale-105"); }
      else { bg.classList.remove("opacity-100"); bg.classList.add("opacity-0", "scale-105"); }
    }

    const badgeEl = document.getElementById("hero-badge");
    if (badgeEl) badgeEl.textContent = d.badge;
    const titleEl = document.getElementById("hero-title");
    if (titleEl) titleEl.textContent = d.title;
    const descEl = document.getElementById("hero-desc");
    if (descEl) descEl.textContent = d.desc;

    document.querySelectorAll<HTMLElement>(".hero-dot").forEach((dot, i) => {
      if (i === idx) { dot.className = "hero-dot h-2 w-8 rounded-full bg-white transition-all duration-500"; }
      else { dot.className = "hero-dot h-2 w-2 rounded-full bg-white/30 transition-all duration-500"; }
    });
  }

  function nextHero() { goHero((currentHero + 1) % totalHero); }
  function startHero() { stopHero(); heroInterval = setInterval(nextHero, 5000); }
  function stopHero() { if (heroInterval) clearInterval(heroInterval); }

  document.querySelectorAll<HTMLElement>(".hero-dot").forEach((dot, i) => {
    dot.addEventListener("click", () => { goHero(i); startHero(); });
  });

  const heroSec = document.getElementById("hero");
  let tx = 0;
  if (heroSec) {
    heroSec.addEventListener("touchstart", e => { tx = e.changedTouches[0].screenX; }, { passive: true });
    heroSec.addEventListener("touchend", e => {
      const diff = tx - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goHero((currentHero + 1) % totalHero);
        else goHero((currentHero - 1 + totalHero) % totalHero);
        startHero();
      }
    }, { passive: true });
  }

  startHero();

  // ====================================================================
  // PROCESS SECTION — Interactive Image + Step List
  // ====================================================================
  const processSection = document.getElementById("alur-maklon");

  // Intersection Observer for scroll-triggered animation
  if (processSection) {
    document.querySelectorAll<HTMLElement>(".process-animate").forEach(el => {
      const obs = new IntersectionObserver(([e]) => {
        if (e.isIntersecting) {
          e.target.classList.add("opacity-100", "translate-y-0");
          e.target.classList.remove("opacity-0", "translate-y-4", "translate-y-6");
          obs.disconnect();
        }
      }, { threshold: 0.3 });
      obs.observe(el);
    });
  }

  // Desktop: Interactive Step Selection
  if (window.innerWidth >= 1024) {
    const totalSteps = processSteps.length;
    let activeDesktop = 0;

    function goToStep(idx: number) {
      if (idx < 0 || idx >= totalSteps || idx === activeDesktop) return;
      activeDesktop = idx;

      // 1. Update featured image
      document.querySelectorAll<HTMLElement>(".process-feature-img").forEach((img, i) => {
        if (i === idx) {
          img.classList.add("opacity-100", "scale-100");
          img.classList.remove("opacity-0", "scale-110");
        } else {
          img.classList.remove("opacity-100", "scale-100");
          img.classList.add("opacity-0", "scale-110");
        }
      });

      // 2. Update image badge
      const step = processSteps[idx];
      const labelEl = document.getElementById("desktop-step-label");
      const titleEl = document.getElementById("desktop-step-title");
      if (labelEl) labelEl.textContent = `TAHAP ${step.step}`;
      if (titleEl) titleEl.textContent = step.title;

      // 3. Update step buttons
      document.querySelectorAll<HTMLElement>(".process-step-btn").forEach((btn, i) => {
        if (i === idx) {
          btn.classList.add("border-primary/30", "bg-primary/[0.04]", "shadow-md", "shadow-primary/5");
          btn.classList.remove("border-base-200/70", "bg-base-100", "shadow-sm");
          // icon
          const icon = btn.querySelector(".rounded-xl");
          if (icon) {
            icon.classList.add("bg-primary", "text-white", "scale-110", "shadow-md");
            icon.classList.remove("bg-primary/10", "text-primary");
          }
          // dot
          const dot = btn.querySelector(".rounded-full");
          if (dot) {
            dot.classList.add("bg-primary", "scale-100");
            dot.classList.remove("bg-transparent", "scale-0");
          }
        } else {
          btn.classList.remove("border-primary/30", "bg-primary/[0.04]", "shadow-md", "shadow-primary/5");
          btn.classList.add("border-base-200/70", "bg-base-100", "shadow-sm");
          const icon = btn.querySelector(".rounded-xl");
          if (icon) {
            icon.classList.remove("bg-primary", "text-white", "scale-110", "shadow-md");
            icon.classList.add("bg-primary/10", "text-primary");
          }
          const dot = btn.querySelector(".rounded-full");
          if (dot) {
            dot.classList.remove("bg-primary", "scale-100");
            dot.classList.add("bg-transparent", "scale-0");
          }
        }
      });
    }

    // Click on step buttons
    document.querySelectorAll<HTMLElement>(".process-step-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = parseInt(btn.getAttribute("data-step") || "0");
        goToStep(idx);
      });
    });

    // Auto-advance every 4s, pause on hover
    let autoTimer: ReturnType<typeof setInterval> | undefined;
    function startAutoAdvance() {
      stopAutoAdvance();
      autoTimer = setInterval(() => {
        const next = (activeDesktop + 1) % totalSteps;
        goToStep(next);
      }, 4000);
    }
    function stopAutoAdvance() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = undefined; }
    }

    const processContainer = document.querySelector(".lg\\:flex");
    if (processContainer) {
      processContainer.addEventListener("mouseenter", stopAutoAdvance);
      processContainer.addEventListener("mouseleave", startAutoAdvance);
    }

    startAutoAdvance();
  }

  // ====================================================================
  // MOBILE — Carousel
  // ====================================================================
  let mobileIdx = 0;
  const mobileTotal = processSteps.length;
  const mobileTrack = document.getElementById("mobile-carousel-track");
  const mobileDots = document.querySelectorAll<HTMLElement>(".mobile-dot");
  const mobileProgress = document.getElementById("mobile-progress");
  const mobileCurrent = document.getElementById("mobile-step-current");
  const mobilePrev = document.getElementById("mobile-prev");
  const mobileNext = document.getElementById("mobile-next");
  let mobileAutoTimer: ReturnType<typeof setInterval> | undefined;

  function goMobile(idx: number) {
    if (!mobileTrack) return;
    mobileIdx = (idx + mobileTotal) % mobileTotal;
    mobileTrack.style.transform = `translateX(-${mobileIdx * 100}%)`;
    if (mobileProgress) mobileProgress.style.width = `${((mobileIdx + 1) / mobileTotal) * 100}%`;
    if (mobileCurrent) mobileCurrent.textContent = String(mobileIdx + 1);

    // Update mobile image
    document.querySelectorAll<HTMLElement>("[id^='mobile-process-img-']").forEach((img, i) => {
      if (i === mobileIdx) {
        img.classList.add("opacity-100", "scale-100");
        img.classList.remove("opacity-0", "scale-110");
      } else {
        img.classList.remove("opacity-100", "scale-100");
        img.classList.add("opacity-0", "scale-110");
      }
    });
    // Update mobile image title
    const titleEl = document.getElementById("mobile-step-title");
    if (titleEl) titleEl.textContent = processSteps[mobileIdx].title;

    mobileDots.forEach((dot, i) => {
      if (i === mobileIdx) {
        dot.className = "mobile-dot w-6 bg-primary rounded-full transition-all duration-400";
      } else {
        dot.className = `mobile-dot h-1.5 w-1.5 rounded-full bg-base-300 transition-all duration-400`;
      }
    });
  }

  function startMobileAuto() { stopMobileAuto(); mobileAutoTimer = setInterval(() => { goMobile(mobileIdx + 1); }, 4000); }
  function stopMobileAuto() { if (mobileAutoTimer) clearInterval(mobileAutoTimer); }
  function resetMobileAuto() { stopMobileAuto(); startMobileAuto(); }

  mobilePrev?.addEventListener("click", () => { goMobile(mobileIdx - 1); resetMobileAuto(); });
  mobileNext?.addEventListener("click", () => { goMobile(mobileIdx + 1); resetMobileAuto(); });

  // Dot click
  mobileDots.forEach((dot, i) => {
    dot.addEventListener("click", () => { goMobile(i); resetMobileAuto(); });
  });

  // Touch swipe
  let touchX = 0;
  const trackContainer = document.getElementById("mobile-carousel-track")?.parentElement;
  trackContainer?.addEventListener("touchstart", (e) => { touchX = e.changedTouches[0].screenX; stopMobileAuto(); }, { passive: true });
  trackContainer?.addEventListener("touchend", (e) => {
    const diff = touchX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 40) {
      goMobile(diff > 0 ? mobileIdx + 1 : mobileIdx - 1);
    }
    resetMobileAuto();
  }, { passive: true });

  startMobileAuto();

  // ====================================================================
  // TESTIMONIAL CAROUSEL
  // ====================================================================
  const track = document.getElementById("testimonial-track");
  const slides = document.querySelectorAll<HTMLElement>(".testimonial-slide");
  const dots = document.querySelectorAll<HTMLElement>(".testi-dot");
  const prevBtn = document.getElementById("testi-prev");
  const nextBtn = document.getElementById("testi-next");
  let testiIdx = 0;
  const testiTotal = slides.length;
  let testiInterval: ReturnType<typeof setInterval> | undefined;

  function updateTesti() {
    if (!track) return;
    track.style.transform = `translateX(-${testiIdx * 100}%)`;
    dots.forEach((d, i) => {
      if (i === testiIdx) { d.className = "testi-dot h-2 w-7 rounded-full bg-primary transition-all duration-400"; }
      else { d.className = "testi-dot h-2 w-2 rounded-full bg-base-300 transition-all duration-400"; }
    });
  }

  function startTesti() { stopTesti(); testiInterval = setInterval(() => { testiIdx = (testiIdx + 1) % testiTotal; updateTesti(); }, 4000); }
  function stopTesti() { if (testiInterval) clearInterval(testiInterval); }
  function resetTesti() { stopTesti(); startTesti(); }

  prevBtn?.addEventListener("click", () => { testiIdx = (testiIdx - 1 + testiTotal) % testiTotal; updateTesti(); resetTesti(); });
  nextBtn?.addEventListener("click", () => { testiIdx = (testiIdx + 1) % testiTotal; updateTesti(); resetTesti(); });
  dots.forEach(d => { d.addEventListener("click", () => { testiIdx = parseInt(d.dataset.index || "0"); updateTesti(); resetTesti(); }); });

  startTesti();
</script>

<style is:global>
  .hero-bg-slide { transition: opacity 1s ease-in-out, transform 1.2s ease-out; }
  #testimonial-track { transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }

  /* Process section animations */
  .process-animate {
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .process-feature-img {
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-step-btn {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-step-btn .rounded-xl {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-step-btn .rounded-full {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #mobile-carousel-track {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #mobile-progress {
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-dot {
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
