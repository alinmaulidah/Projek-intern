---
import Icon from "../components/ui/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { advantages } from "../data/advantages";
import { services } from "../data/services";
import { processSteps } from "../data/process";
import { products } from "../data/products";
import { testimonials } from "../data/testimonials";
import { faqs } from "../data/faqs";
import { categoryImages, factoryImages, processImages, productImages, heroImages } from "../data/images";
import { certifications } from "../data/certifications";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
const waKonsultasi = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi mengenai maklon skincare/kosmetik.");
const processPreviewSteps = processSteps.slice(0, 5);
const topProducts = products.slice(0, 8);
const categories = categoryImages.slice(0, 6);

const heroSlides = [
  { image: heroImages.skincareLab, label: "Laboratorium Modern", subtitle: "Formulasi presisi dengan teknologi terkini" },
  { image: heroImages.skincareProduction, label: "Produksi Berkualitas", subtitle: "Standar CPKB & GMP terjaga ketat" },
  { image: heroImages.packagingReady, label: "Siap Dikemas & Kirim", subtitle: "Produk jadi langsung siap distribusi" },
  { image: heroImages.labResearch, label: "Riset & Inovasi", subtitle: "500+ formula siap dikustomisasi" },
];

const galleryItems = [
  { label: "Laboratorium R&D", image: factoryImages.labResearch, icon: "lucide:flask-conical" },
  { label: "Ruang QC", image: factoryImages.qualityControl, icon: "lucide:microscope" },
  { label: "Lini Produksi", image: factoryImages.productionLine, icon: "lucide:factory" },
  { label: "Area Pengemasan", image: factoryImages.packagingArea, icon: "lucide:package" },
  { label: "Ruang Sampling", image: factoryImages.samplingRoom, icon: "lucide:beaker" },
  { label: "Gudang Bahan Baku", image: factoryImages.bahanBaku, icon: "lucide:warehouse" },
];

const comparisons = [
  { aspect: "Kepemilikan Pabrik", us: "Pabrik Milik Sendiri", them: "Sering pihak ketiga" },
  { aspect: "Formulasi", us: "Custom 500+ Formula", them: "Terbatas / template" },
  { aspect: "Legalitas", us: "BPOM + Halal + HKI", them: "Belum tentu lengkap" },
  { aspect: "MOQ", us: "Fleksibel", them: "Cenderung tinggi" },
  { aspect: "Pendampingan", us: "Konsultasi gratis", them: "Sering terbatas" },
];
---

<MainLayout
  title="Aquila Magna – Jasa Maklon Skincare & Kosmetik Terpercaya"
  description={siteConfig.description}
>
  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. HERO — Fullscreen Image Slider                                  -->
    <!-- ================================================================== -->
    <section id="hero" class="relative flex min-h-screen items-end pb-16 md:items-center md:pb-0">
      <!-- Background Slides -->
      <div class="absolute inset-0 z-0">
        {heroSlides.map((slide, idx) => (
          <div
            class="hero-slide absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 ease-in-out"
            class:list={{ "opacity-100": idx === 0, "opacity-0": idx !== 0 }}
            style={`background-image: url('${slide.image}')`}
          ></div>
        ))}
        <!-- Dark overlay -->
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/75 md:bg-gradient-to-r md:from-black/75 md:via-black/50 md:to-black/60"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 mx-auto w-full max-w-7xl px-4 pb-8 md:pb-0 lg:px-8">
        <div class="max-w-2xl">
          <!-- Live badge -->
          <div class="mb-6 inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/8 px-5 py-2.5 backdrop-blur-lg">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inset-0 animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </span>
            <span class="text-xs font-bold tracking-[0.16em] text-white/80 uppercase">Partner Maklon Profesional</span>
          </div>

          <h1 class="text-4xl font-black leading-[1.06] text-white md:text-5xl lg:text-6xl xl:text-7xl">
            Wujudkan Brand<br />
            <span class="bg-gradient-to-r from-emerald-300 via-green-200 to-white bg-clip-text text-transparent">
              Kecantikan Anda
            </span>
          </h1>

          <p class="mt-5 max-w-lg text-sm leading-relaxed text-white/55 md:text-base lg:text-lg">
            Dari formulasi, produksi, legalitas BPOM & Halal, hingga produk siap jual —
            <span class="font-semibold text-white/75">kami dampingi penuh</span>.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href={waKonsultasi} target="_blank" rel="noopener noreferrer"
              class="group relative inline-flex h-14 items-center gap-2.5 overflow-hidden rounded-xl bg-white px-8 text-base font-bold text-primary shadow-xl shadow-black/20 transition-all duration-500 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-primary/15">
              <Icon name="mdi:whatsapp" class="relative z-10 h-5 w-5" />
              <span class="relative z-10">Konsultasi Gratis</span>
              <Icon name="lucide:arrow-right" class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
            </a>
            <a href="/alur-maklon"
              class="group inline-flex h-14 items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 text-sm font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10">
              Lihat Alur Maklon
              <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
            </a>
          </div>

          <!-- Trust badges -->
          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2">
            {["BPOM Terdaftar", "Sertifikat Halal MUI", "ISO 9001:2015", "CPKB Certified"].map((t) => (
              <span class="inline-flex items-center gap-1.5 text-[11px] font-medium text-white/35">
                <Icon name="lucide:shield-check" class="h-3 w-3 text-emerald-400/30" />
                {t}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Slide indicators -->
      <div class="absolute bottom-8 right-4 z-10 flex items-center gap-2 md:right-8 lg:right-12">
        {heroSlides.map((_, idx) => (
          <button
            class="hero-dot h-1.5 rounded-full bg-white transition-all duration-500"
            class:list={{ "w-8 bg-white": idx === 0, "w-1.5 bg-white/30 hover:bg-white/50": idx !== 0 }}
            data-slide={idx}
            aria-label={`Slide ${idx + 1}`}
          ></button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CATEGORY — Grid cards seperti Layanan (4 kolom)                   -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary text-xs font-bold tracking-widest uppercase">Kategori Produk</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl lg:text-5xl">
            Semua Kategori<br class="hidden sm:block" /> Produk Kecantikan
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-base-content/45 md:text-base">
            Dari skincare hingga baby care — semua bisa diproduksi dalam satu tempat.
          </p>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {categories.map((cat) => {
            const waCat = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan produk kategori ${cat.name}. Bisa info lebih lanjut?`);
            return (
              <a href={waCat} target="_blank" rel="noopener noreferrer"
                class="group relative block overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl"
              >
                <div class="relative aspect-[4/5] w-full overflow-hidden">
                  <img src={cat.image} alt={cat.name} class="h-full w-full object-cover transition-all duration-700 ease-out group-hover:scale-105" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-5">
                    <h3 class="text-lg font-bold text-white drop-shadow-md">{cat.name}</h3>
                  </div>
                  <!-- Hover overlay -->
                  <div class="absolute inset-0 flex items-center justify-center bg-black/45 opacity-0 backdrop-blur-[1px] transition-all duration-500 group-hover:opacity-100">
                    <span class="translate-y-3 rounded-xl bg-white px-6 py-2.5 text-sm font-bold text-primary shadow-lg transition-transform duration-500 group-hover:translate-y-0">
                      Konsultasi {cat.name}
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. STATS — Animated counters                                        -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-primary py-16 md:py-20">
      <!-- Decorative overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary to-primary/90"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
          {[
            { value: 500, suffix: "+", label: "Formula" },
            { value: 200, suffix: "+", label: "Brand Partner" },
            { value: 10, suffix: "+", label: "Tahun" },
            { value: 50, suffix: "+", label: "Tenaga Ahli" },
          ].map((stat) => (
            <div class="group relative overflow-hidden rounded-2xl border border-white/15 bg-white/10 p-6 text-center backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:border-white/25 hover:bg-white/15">
              <p class="text-3xl font-black text-white tabular-nums">
                <span class="stat-counter" data-target={stat.value}>{stat.value}</span>{stat.suffix}
              </p>
              <p class="mt-1 text-xs font-semibold tracking-wider text-white/60 uppercase">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. LAYANAN — Service cards with image hover overlay                 -->
    <!-- ================================================================== -->
    <section id="layanan" class="bg-base-100 py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary text-xs font-bold tracking-widest uppercase">Layanan Maklon</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl lg:text-5xl">
            Solusi Lengkap untuk<br class="hidden sm:block" /> Brand Kecantikan Anda
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-base-content/45 md:text-base">
            Dari skincare hingga parfum — semua bisa kami produksi dengan standar kualitas tinggi.
          </p>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((svc) => {
            const waService = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan layanan ${svc.title}. Bisa info lebih lanjut?`);
            return (
              <a href={waService} target="_blank" rel="noopener noreferrer"
                class="service-card group relative block overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl"
              >
                <div class="relative aspect-[4/5] w-full overflow-hidden">
                  <img src={svc.image} alt={svc.title} class="h-full w-full object-cover transition-all duration-700 ease-out group-hover:scale-105" loading="lazy" />
                  <!-- Bottom title on idle -->
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 via-black/30 to-transparent p-5">
                    <h3 class="text-lg font-bold text-white drop-shadow-md">{svc.title}</h3>
                  </div>
                  <!-- Hover overlay -->
                  <div class="absolute inset-0 flex flex-col justify-center bg-black/55 p-6 opacity-0 backdrop-blur-[2px] transition-all duration-500 group-hover:opacity-100">
                    <div class="translate-y-3 transition-transform duration-500 group-hover:translate-y-0">
                      <p class="text-sm leading-relaxed text-white/90">{svc.desc}</p>
                      {svc.examples && svc.examples.length > 0 && (
                        <div class="mt-3 flex flex-wrap gap-1.5">
                          {svc.examples.split(",").slice(0, 4).map((ex: string) => (
                            <span class="rounded-lg bg-white/15 px-2.5 py-0.5 text-[11px] font-medium text-white/85 backdrop-blur-sm">{ex.trim()}</span>
                          ))}
                        </div>
                      )}
                      <span class="mt-5 inline-flex items-center gap-2 rounded-xl bg-white px-5 py-2.5 text-sm font-bold text-primary shadow-lg transition-all duration-300 hover:bg-white/95">
                        Konsultasi
                        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <div class="mt-10 text-center">
          <a href="/layanan" class="btn btn-outline btn-primary">
            Lihat Semua Layanan
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. KEUNGGULAN — Icon cards with hover accent                        -->
    <!-- ================================================================== -->
    <section id="keunggulan" class="bg-base-200/50 py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary text-xs font-bold tracking-widest uppercase">Mengapa Kami</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl lg:text-5xl">Keunggulan Aquila Magna</h2>
          <p class="mt-4 text-sm leading-relaxed text-base-content/45 md:text-base">
            Setiap detail kami perhatikan — dari formula hingga pengiriman.
          </p>
        </div>

        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {advantages.map((adv) => (
            <div class="group flex items-start gap-5 rounded-2xl border border-base-200/70 bg-white p-6 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/15">
                <Icon name={adv.icon} class="h-6 w-6" />
              </div>
              <div>
                <h3 class="text-base font-bold transition-colors duration-300 group-hover:text-primary">{adv.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-base-content/50">{adv.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 6. PRODUCT SHOWCASE — Modern hover cards                            -->
    <!-- ================================================================== -->
    <section id="produk" class="bg-base-100 py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary text-xs font-bold tracking-widest uppercase">Produk Maklon</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl lg:text-5xl">Produk yang Bisa Kami Buat</h2>
          <p class="mt-4 text-sm leading-relaxed text-base-content/45 md:text-base">
            Berbagai kategori produk kecantikan siap diproduksi sesuai kebutuhan brand Anda.
          </p>
        </div>

        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {topProducts.map((product) => (
            <div class="group relative overflow-hidden rounded-2xl border border-base-200/70 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/15 hover:shadow-lg">
              <div class="relative h-48 overflow-hidden">
                <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-white/90 via-white/20 to-transparent"></div>
                <span class="absolute left-3 top-3 rounded-lg bg-white/90 px-2.5 py-1 text-[10px] font-bold text-primary shadow-sm backdrop-blur-sm">{product.category}</span>
              </div>
              <div class="p-5">
                <h3 class="text-sm font-bold">{product.name}</h3>
                <p class="mt-1 text-xs leading-relaxed text-base-content/45 line-clamp-2">{product.desc}</p>
                <div class="mt-4 flex items-center gap-1 text-[11px] font-semibold text-primary opacity-0 transition-all duration-300 group-hover:opacity-100">
                  <span>Info Selengkapnya</span>
                  <Icon name="lucide:arrow-right" class="h-3 w-3" />
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/produk-maklon" class="btn btn-outline btn-primary">
            Lihat Semua Produk
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 7. PROCESS — Interactive timeline + mobile carousel                 -->
    <!-- ================================================================== -->
    <section id="alur" class="bg-base-200/50 py-20 md:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary text-xs font-bold tracking-widest uppercase">Alur Maklon</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl lg:text-5xl">Proses Mudah & Transparan</h2>
          <p class="mt-4 text-sm leading-relaxed text-base-content/45 md:text-base">
            Dari konsultasi hingga produk sampai — semua jelas dan terarah.
          </p>
        </div>

        <!-- DESKTOP: Interactive timeline -->
        <div class="mt-14 hidden gap-8 lg:flex">
          <div class="w-[42%] space-y-2">
            {processPreviewSteps.map((step, idx) => (
              <button
                class="process-btn group flex w-full items-center gap-4 rounded-xl border p-4 text-left transition-all duration-500"
                class:list={{
                  "border-primary/30 bg-primary/[0.04] shadow-md": idx === 0,
                  "border-base-200/70 bg-white shadow-sm hover:border-primary/20 hover:bg-primary/[0.02]": idx !== 0,
                }}
                data-step={idx}
              >
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-500 group-[.border-primary/30]:bg-primary group-[.border-primary/30]:text-white group-[.border-primary/30]:shadow-md group-[.border-primary/30]:shadow-primary/20">
                  <Icon name={step.icon} class="h-5 w-5" />
                </div>
                <div class="text-left">
                  <span class="text-[10px] font-bold tracking-[0.15em] text-primary/50 uppercase">Tahap {step.step}</span>
                  <h3 class="text-sm font-bold">{step.title}</h3>
                </div>
                <div class="ml-auto h-2 w-2 shrink-0 rounded-full bg-transparent transition-all duration-500 group-[.border-primary/30]:bg-primary group-[.border-primary/30]:scale-100 scale-0"></div>
              </button>
            ))}
          </div>

          <div class="w-[58%]">
            <div class="sticky top-24 overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-lg">
              <div class="relative aspect-[4/3] bg-base-200">
                {processPreviewSteps.map((step, idx) => (
                  <img
                    id={`process-img-${idx}`}
                    class="process-img absolute inset-0 h-full w-full object-cover"
                    class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                    src={processImages[step.imageKey]}
                    alt={step.title}
                    loading={idx === 0 ? "eager" : "lazy"}
                  />
                ))}
                <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-black/50 to-transparent"></div>
                <div class="absolute bottom-6 left-6 flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/20 text-white backdrop-blur-md">
                    <Icon id="process-slide-icon" name={processPreviewSteps[0].icon} class="h-5 w-5" />
                  </div>
                  <div>
                    <span id="process-step-label" class="text-[10px] font-bold tracking-wider text-white/60 uppercase">Tahap 1</span>
                    <h3 id="process-step-title" class="text-lg font-bold text-white">{processPreviewSteps[0].title}</h3>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- MOBILE: Card carousel -->
        <div class="mt-10 lg:hidden">
          <div class="relative">
            <div class="mb-4 flex items-center gap-3">
              <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-base-200">
                <div id="mobile-progress" class="h-full rounded-full bg-primary transition-all duration-500 ease-out" style="width: 20%"></div>
              </div>
              <span class="text-xs font-bold text-base-content/40">
                <span id="mobile-current">1</span>/<span>{processPreviewSteps.length}</span>
              </span>
            </div>
            <div class="overflow-hidden rounded-2xl shadow-md">
              <div class="relative aspect-[16/9] bg-base-200">
                {processPreviewSteps.map((step, idx) => (
                  <img
                    id={`mobile-img-${idx}`}
                    class="absolute inset-0 h-full w-full object-cover transition-all duration-600 ease-in-out"
                    class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                    src={processImages[step.imageKey]}
                    alt={step.title}
                    loading="lazy"
                  />
                ))}
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                <div class="absolute bottom-4 left-4 flex items-center gap-2">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/20 text-white backdrop-blur-md">
                    <Icon id="mobile-slide-icon" name={processPreviewSteps[0].icon} class="h-4 w-4" />
                  </div>
                  <span id="mobile-title" class="text-sm font-bold text-white">{processPreviewSteps[0].title}</span>
                </div>
              </div>
            </div>
            <div class="mt-3 overflow-hidden rounded-2xl">
              <div id="mobile-track" class="flex transition-transform duration-500 ease-out">
                {processPreviewSteps.map((step) => (
                  <div class="w-full shrink-0 px-0.5">
                    <div class="rounded-2xl border border-base-200 bg-white p-4 shadow-sm">
                      <div class="flex items-center gap-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                          <Icon name={step.icon} class="h-5 w-5" />
                        </div>
                        <div>
                          <span class="text-[10px] font-bold tracking-wider text-primary/50">TAHAP {step.step}</span>
                          <h3 class="text-sm font-bold">{step.title}</h3>
                        </div>
                      </div>
                      <p class="mt-2 text-sm leading-relaxed text-base-content/60">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between">
