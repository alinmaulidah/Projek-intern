---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { companyImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
---

<MainLayout
  title="Kontak | Aquila Magna"
  description="Hubungi kami untuk konsultasi maklon skincare dan kosmetik."
>
  <main>
    <!-- Page Hero -->
    <section class="relative overflow-hidden bg-gradient-to-b from-base-100 to-base-200 pb-16 pt-28 md:pt-36">
      <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-secondary/10 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <nav class="mb-6 flex items-center justify-center gap-2 text-sm text-base-content/50">
            <a href="/" class="transition-colors hover:text-primary">Home</a>
            <span>/</span>
            <span class="text-base-content/80 font-medium">Kontak</span>
          </nav>

          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Kontak</span>
          <h1 class="text-4xl font-black md:text-5xl lg:text-6xl">Kontak Kami</h1>
          <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-base-content/70 md:text-xl">
            Siap memulai? Hubungi kami untuk konsultasi. Tim kami siap membantu Anda mewujudkan produk impian.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body items-center text-center p-6">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-green-100 text-3xl"><Icon name="mdi:whatsapp" size={32} class="text-green-600" /></div>
            <h3 class="card-title mt-3">WhatsApp</h3>
            <p class="mt-1 text-sm text-base-content/60">{siteConfig.waNumber}</p>
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm mt-3 rounded-full px-5 text-white">
              Chat Sekarang
            </a>
          </div>
        </div>

        <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body items-center text-center p-6">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-100 text-3xl"><Icon name="lucide:mail" size={32} class="text-blue-600" /></div>
            <h3 class="card-title mt-3">Email</h3>
            <p class="mt-1 text-sm text-base-content/60">{siteConfig.email}</p>
            <a href={`mailto:${siteConfig.email}`} class="btn btn-soft btn-sm mt-3 rounded-full px-5">
              Kirim Email
            </a>
          </div>
        </div>

        <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body items-center text-center p-6">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-100 text-3xl"><Icon name="lucide:map-pin" size={32} class="text-purple-600" /></div>
            <h3 class="card-title mt-3">Lokasi</h3>
            <p class="mt-1 text-sm text-base-content/60">{siteConfig.address}</p>
          </div>
        </div>

        <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body items-center text-center p-6">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-orange-100 text-3xl"><Icon name="lucide:clock" size={32} class="text-orange-600" /></div>
            <h3 class="card-title mt-3">Jam Operasional</h3>
            <p class="mt-1 text-sm text-base-content/60">{siteConfig.operationalHours}</p>
          </div>
        </div>
      </div>

      <!-- Map / Office Photo -->
      <div class="mt-10">
        <div class="card border border-base-200 bg-base-100 shadow-sm">
          <div class="card-body p-6">
            <figure class="relative h-64 w-full overflow-hidden rounded-2xl">
              <img src={companyImages.building} alt="Aquila Magna Office" class="h-full w-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-6 left-6">
                <p class="text-lg font-semibold text-white">Alamat Kantor</p>
                <p class="text-sm text-white/80">{siteConfig.address}</p>
                <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm mt-3 rounded-full px-5 text-white">
                  Tanya Lokasi via WhatsApp
                </a>
              </div>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- Form Konsultasi -->
    <section class="bg-base-200/50 py-16">
      <div class="mx-auto max-w-4xl px-4 lg:px-8">
        <div class="text-center mb-12">
          <p class="mb-3 font-semibold tracking-wide text-primary">Form Konsultasi</p>
          <h2 class="text-3xl font-black md:text-4xl">Mulai Konsultasi Produk Anda</h2>
          <p class="mx-auto mt-4 max-w-2xl text-base-content/70 md:text-lg">
            Isi form di bawah dan tim kami akan menghubungi Anda untuk konsultasi lebih lanjut.
          </p>
        </div>

        <div class="card border border-base-200 bg-base-100 shadow-lg">
          <div class="card-body p-6 md:p-10">
            <form class="space-y-6" data-wa-number={siteConfig.waNumber} id="consultForm">
              <div class="grid gap-6 md:grid-cols-2">
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Nama Lengkap <span class="text-error">*</span></span>
                  </label>
                  <input type="text" id="nama" name="nama" placeholder="Masukkan nama lengkap" required class="input input-bordered w-full" />
                </div>
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Nomor WhatsApp <span class="text-error">*</span></span>
                  </label>
                  <input type="tel" id="wa" name="wa" placeholder="Contoh: 08123456789" required class="input input-bordered w-full" />
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Email</span>
                  </label>
                  <input type="email" id="email" name="email" placeholder="contoh@email.com" class="input input-bordered w-full" />
                </div>
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Jenis Produk <span class="text-error">*</span></span>
                  </label>
                  <select id="produk" name="produk" required class="select select-bordered w-full">
                    <option value="" disabled selected>Pilih jenis produk</option>
                    <option value="Skincare">Skincare</option>
                    <option value="Bodycare">Bodycare</option>
                    <option value="Haircare">Haircare</option>
                    <option value="Parfum">Parfum / Fragrance</option>
                    <option value="Makeup">Makeup / Kosmetik</option>
                    <option value="Baby Care">Baby Care</option>
                    <option value="Lainnya">Lainnya</option>
                  </select>
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div class="form-control">
                  <label class="label">
                    <span class="label-text font-medium">Estimasi Jumlah Produksi</span>
                  </label>
                  <select id="estimasi" name="estimasi" class="select select-bordered w-full">
                    <option value="" disabled selected>Pilih estimasi</option>
                    <option value="500-1000 pcs">500 - 1000 pcs</option>
                    <option value="1000-5000 pcs">1000 - 5000 pcs</option>
                    <option value="5000-10000 pcs">5000 - 10.000 pcs</option>
                    <option value="10000+ pcs">10.000+ pcs</option>
                    <option value="Belum tahu">Belum tahu</option>
                  </select>
                </div>
                <div class="form-control"></div>
              </div>

              <div class="form-control">
                <label class="label">
                  <span class="label-text font-medium">Pesan Tambahan</span>
                </label>
                <textarea id="pesan" name="pesan" class="textarea textarea-bordered h-32" placeholder="Ceritakan ide produk Anda..."></textarea>
              </div>

              <div class="text-center">
                <button type="submit" class="btn btn-primary btn-lg rounded-full px-10 text-white shadow-lg transition-all duration-300 hover:shadow-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="mr-2">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Kirim Konsultasi
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <script>
      import { createConsultationMessage, createWhatsappLink } from "../lib/whatsapp";

      document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('consultForm');
        if (!form) return;
        const waNumber = form.getAttribute('data-wa-number');
        if (!waNumber) return;
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          const getValue = (id: string) => {
            const field = document.getElementById(id);
            return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement ? field.value : '';
          };
          const nama = getValue('nama');
          const wa = getValue('wa');
          const email = getValue('email');
          const produk = getValue('produk');
          const estimasi = getValue('estimasi');
          const pesan = getValue('pesan');

          const message = createConsultationMessage({ nama, wa, email, produk, estimasi, pesan });

          window.open(createWhatsappLink(waNumber, message), '_blank', 'noopener,noreferrer');
        });
      });
    </script>
  </main>
</MainLayout>