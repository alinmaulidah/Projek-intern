---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { portfolioItems } from "../data/portofolio";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya tertarik untuk memulai brand skincare bersama Aquila Maklon.");
---

<MainLayout
  title="Portofolio | Aquila Maklon"
  description="Lihat portofolio brand-brand yang telah bekerja sama dengan Aquila Maklon dalam produksi skincare dan kosmetik."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. PORTOFOLIO — Image only, 4 columns, hover shows details         -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pt-16 pb-20 lg:pt-24 lg:pb-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
          {portfolioItems.map((item) => (
            <div
              class="porto-card group relative overflow-hidden rounded-2xl border border-base-200 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl hover:border-primary/20"
              style="opacity:0;transform:translateY(30px)"
              data-porto-card
            >
              {/* Tall image */}
              <div class="relative h-72 overflow-hidden sm:h-80 lg:h-96">
                <img
                  src={item.image}
                  alt={item.brandName}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />

                {/* Brand name at bottom */}
                <div class="porto-brand-label absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-3 sm:p-4">
                  <h3 class="text-sm font-bold leading-tight text-white sm:text-base">{item.brandName}</h3>
                </div>

                {/* OVERLAY — white popup with details */}
                <div class="porto-overlay absolute inset-0 flex-col justify-end bg-white/95 p-4 sm:p-5" style="display: none">
                  {/* Close button for mobile tap */}
                  <button class="porto-close absolute right-3 top-3 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-base-200/80 text-base-content/60 transition-colors hover:bg-base-300 hover:text-base-content sm:hidden" aria-label="Tutup detail" type="button">
                    <Icon name="lucide:x" size={14} />
                  </button>

                  {/* Brand name */}
                  <h3 class="text-base font-bold text-base-content sm:text-lg leading-tight mb-1">{item.brandName}</h3>

                  {/* Description */}
                  <p class="text-xs leading-relaxed text-base-content/65 line-clamp-3 mb-3">{item.description}</p>

                  {/* Products tags */}
                  <div class="flex flex-wrap gap-1 mb-3">
                    {item.products.slice(0, 4).map((product) => (
                      <span class="rounded-full border border-base-200 bg-base-200/50 px-2 py-0.5 text-[10px] font-medium text-base-content/55">
                        {product}
                      </span>
                    ))}
                  </div>

                  {/* Highlights */}
                  <div class="space-y-1 mb-4">
                    {item.highlights.slice(0, 2).map((highlight) => (
                      <div class="flex items-start gap-1.5">
                        <div class="mt-0.5 flex h-3 w-3 shrink-0 items-center justify-center rounded-full bg-primary/10">
                          <Icon name="lucide:check" size={8} class="text-primary" />
                        </div>
                        <span class="text-[10px] text-base-content/65 leading-tight">{highlight}</span>
                      </div>
                    ))}
                  </div>
                </div>

                {/* Tap indicator for mobile */}
                <div class="porto-tap-indicator absolute right-3 top-3 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-black/40 transition-opacity duration-300 sm:hidden">
                  <Icon name="lucide:info" size={14} class="text-white" />
                </div>
              </div>

              {/* CTA button below image */}
              <a
                href={createWhatsappLink(
                  siteConfig.waNumber,
                  `Halo, saya tertarik dengan portofolio ${item.brandName}. Saya ingin konsultasi untuk membuat produk serupa.`
                )}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center justify-center gap-1.5 border-t border-base-100 bg-primary/5 px-3 py-2.5 text-xs font-semibold text-primary transition-all duration-300 hover:bg-primary hover:text-white"
              >
                Konsultasi Produk Serupa
                <Icon name="lucide:arrow-right" size={12} class="transition-transform duration-300 group-hover:translate-x-1" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CTA PREMIUM BANNER                                               -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary/80"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-5xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm">
          <Icon name="lucide:star" size={36} class="text-white" />
        </div>

        <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl leading-tight">
          Jadilah Brand Selanjutnya!
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base text-white/70 md:text-lg leading-relaxed">
          Bergabunglah dengan brand-brand sukses lainnya. Mulai perjalanan brand Anda bersama Aquila Maklon — dari formulasi hingga produk siap jual.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-xl border-2 border-white bg-white px-10 text-base font-bold text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" size={20} />
            Konsultasi via WhatsApp
            <Icon name="lucide:arrow-right" size={18} />
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // Scroll-triggered animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          el.style.transition = "all 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.1s";
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px 50px 0px" }
  );

  // Tap/click toggle for mobile + desktop
  document.querySelectorAll("[data-porto-card]").forEach((card) => {
    observer.observe(card);

    const overlay = card.querySelector(".porto-overlay") as HTMLElement;
    const brandLabel = card.querySelector(".porto-brand-label") as HTMLElement;
    const tapIndicator = card.querySelector(".porto-tap-indicator") as HTMLElement;
    const closeBtn = card.querySelector(".porto-close");

    if (!overlay) return;

    // Show tap indicator on touch devices
    const isTouchDevice = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    if (isTouchDevice && tapIndicator) {
      tapIndicator.style.opacity = "1";
    }

    function openOverlay() {
      // Close all other open cards first
      document.querySelectorAll("[data-porto-card].porto-card-active").forEach((other) => {
        if (other !== card) closeCard(other as HTMLElement);
      });
      card.classList.add("porto-card-active");
      overlay.style.display = "flex";
      overlay.style.opacity = "1";
      if (brandLabel) brandLabel.style.opacity = "0";
      if (tapIndicator) tapIndicator.style.opacity = "0";
    }

    function closeOverlay() {
      card.classList.remove("porto-card-active");
      overlay.style.display = "none";
      overlay.style.opacity = "";
      if (brandLabel) brandLabel.style.opacity = "";
      if (tapIndicator && isTouchDevice) tapIndicator.style.opacity = "1";
    }

    function closeCard(c: HTMLElement) {
      c.classList.remove("porto-card-active");
      const ovl = c.querySelector(".porto-overlay") as HTMLElement;
      const lbl = c.querySelector(".porto-brand-label") as HTMLElement;
      const ind = c.querySelector(".porto-tap-indicator") as HTMLElement;
      if (ovl) { ovl.style.display = "none"; ovl.style.opacity = ""; }
      if (lbl) lbl.style.opacity = "";
      if (ind && isTouchDevice) ind.style.opacity = "1";
    }

    card.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) return;
      if ((e.target as HTMLElement).closest(".porto-close")) return;

      if (card.classList.contains("porto-card-active")) {
        closeOverlay();
      } else {
        openOverlay();
      }
    });

    if (closeBtn) {
      closeBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        closeOverlay();
      });
    }
  });

  // Close overlay when tapping outside
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("[data-porto-card]")) {
      document.querySelectorAll("[data-porto-card].porto-card-active").forEach((card) => {
        card.classList.remove("porto-card-active");
        const ovl = card.querySelector(".porto-overlay") as HTMLElement;
        const lbl = card.querySelector(".porto-brand-label") as HTMLElement;
        const ind = card.querySelector(".porto-tap-indicator") as HTMLElement;
        if (ovl) { ovl.style.display = "none"; ovl.style.opacity = ""; }
        if (lbl) lbl.style.opacity = "";
        const isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
        if (ind && isTouch) ind.style.opacity = "1";
      });
    }
  });
</script>
