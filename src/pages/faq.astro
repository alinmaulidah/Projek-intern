---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { faqs } from "../data/faqs";
import Icon from "../components/ui/Icon.astro";
---

<MainLayout
  title="FAQ | Aquila Magna"
  description="Pertanyaan yang sering diajukan seputar layanan maklon skincare dan kosmetik."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. PAGE HEADER                                                     -->
    <!-- ================================================================== -->
    <PageHeader
      title="Pertanyaan yang Sering Diajukan"
      description="Temukan jawaban untuk pertanyaan umum seputar layanan maklon kami. Jika masih ada yang ingin ditanyakan, jangan ragu untuk menghubungi kami."
      badge="FAQ"
    />

    <!-- Accordion FAQ -->
    <section class="mx-auto max-w-3xl px-4 py-16 lg:px-8">
      <div class="join join-vertical w-full space-y-2">
        {faqs.map((faq) => (
          <div class="collapse collapse-arrow join-item border border-base-200 bg-base-100 rounded-2xl shadow-sm">
            <input type="radio" name="faq-accordion" />
            <div class="collapse-title text-lg font-medium">{faq.q}</div>
            <div class="collapse-content">
              <p class="text-base-content/70 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center p-8 rounded-3xl bg-base-200/50">
        <p class="text-lg font-semibold">Masih Punya Pertanyaan?</p>
        <p class="mt-2 text-base-content/70">Jangan ragu untuk menghubungi tim kami. Kami siap membantu Anda.</p>
        <a href={createWhatsappLink(siteConfig.waNumber, siteConfig.waText)} target="_blank" rel="noopener noreferrer" class="btn btn-primary mt-4 rounded-full px-8 text-white shadow-md">
          <Icon name="mdi:whatsapp" class="mr-2 h-4 w-4" />
          Konsultasi via WhatsApp
        </a>
      </div>
    </section>
  </main>
</MainLayout>