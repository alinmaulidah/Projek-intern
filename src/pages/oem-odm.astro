---
import Icon from "../components/ui/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import CTASection from "../components/sections/CTASection.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { oemOdmStats, oemOdmProcess, oemOdmAdvantages } from "../data/oem-odm";
import { factoryImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi layanan OEM/ODM.");
---

<MainLayout
  title="OEM / ODM | Aquila Maklon"
  description="Layanan OEM dan ODM maklon skincare & kosmetik. Produksi brand Anda dengan standar kualitas premium."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. HERO — 2-column layout                                          -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-b from-base-100 to-base-200 pb-16 pt-28 md:pt-36">
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-primary/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-secondary/5 blur-3xl"></div>

      <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 lg:flex-row lg:px-8">
        <!-- LEFT: Text -->
        <div class="flex-1 text-center lg:text-left">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-5 py-1.5 text-xs font-semibold tracking-[0.15em] text-primary">
            <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
            OEM / ODM
          </span>
          <h1 class="mt-4 text-4xl font-black leading-tight md:text-5xl lg:text-6xl">
            Produksi Brand<br /><span class="text-primary">Skincare & Kosmetik</span>
          </h1>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-base-content/60 md:text-lg">
            Layanan OEM (Original Equipment Manufacturing) dan ODM (Original Design Manufacturing) untuk brand Anda. Dari konsep hingga produk siap jual dengan standar kualitas premium.
          </p>
          <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="group inline-flex h-14 items-center gap-2 rounded-full bg-primary px-8 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition-all duration-500 hover:scale-105 hover:shadow-xl">
              <Icon name="mdi:whatsapp" class="h-4 w-4" />
              Konsultasi OEM/ODM
            </a>
            <a href="#process" class="group inline-flex h-14 items-center gap-2 rounded-full border border-base-300 bg-base-100 px-8 text-sm font-medium text-base-content/70 shadow-sm transition-all duration-500 hover:border-primary/30 hover:text-primary">
              Lihat Proses
              <Icon name="chevron-down" class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5" />
            </a>
          </div>
        </div>

        <!-- RIGHT: Image -->
        <div class="flex-1">
          <div class="relative mx-auto aspect-[4/3] w-full max-w-lg overflow-hidden rounded-3xl shadow-2xl">
            <img src={factoryImages.productionLine} alt="OEM ODM Production" class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            <div class="absolute bottom-4 left-4 rounded-full bg-white/90 px-4 py-2 text-xs font-bold text-primary shadow-lg backdrop-blur-sm">
              <Icon name="factory" class="mr-1 inline h-3 w-3" /> Maklon Premium
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. STATS — Bar stats                                               -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary to-emerald-900 py-16">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 50px 50px;"></div>
      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          {oemOdmStats.map(function(stat) {
            return (
              <div class="text-center">
                <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-2xl border border-white/[0.08] bg-white/[0.05] shadow-lg backdrop-blur-sm transition-all duration-500 hover:scale-110 hover:border-white/[0.15]">
                  <span class="text-3xl font-black text-white">{stat.value}</span>
                </div>
                <p class="mt-3 text-sm font-medium text-white/60">{stat.label}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. PROSES OEM-ODM — Timeline/interactive                          -->
    <!-- ================================================================== -->
    <section id="process" class="bg-base-100 py-20 md:py-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-5 py-1.5 text-xs font-semibold tracking-[0.15em] text-primary">
            <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
            PROSES OEM/ODM
          </span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl">Bagaimana Kami Bekerja</h2>
          <p class="mt-3 text-base-content/55">Tahapan jelas dari awal hingga produk jadi.</p>
        </div>

        <div class="mt-14 space-y-6">
          {oemOdmProcess.map(function(item, i) {
            return (
              <div class="process-card group relative overflow-hidden rounded-2xl border border-base-200/80 bg-base-100 p-6 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 md:p-8">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:gap-8">
                  <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-primary/80 text-xl font-black text-white shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl">
                    {item.step}
                  </div>
                  <div class="flex-1">
                    <h3 class="text-lg font-bold transition-colors duration-300 group-hover:text-primary">{item.title}</h3>
                    <p class="mt-1 text-sm leading-relaxed text-base-content/55">{item.desc}</p>
                  </div>
                  <div class="hidden text-5xl font-black text-base-200/50 transition-all duration-500 group-hover:text-primary/[0.04] md:block">{item.step}</div>
                </div>
                {i < oemOdmProcess.length - 1 && (
                  <div class="absolute bottom-0 left-12 h-6 w-0.5 bg-gradient-to-b from-base-300 to-transparent"></div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. KEUNGGULAN OEM — Grid cards                                     -->
    <!-- ================================================================== -->
    <section class="bg-base-200/40 py-20 md:py-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/[0.04] px-5 py-1.5 text-xs font-semibold tracking-[0.15em] text-primary">
            <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
            KEUNGGULAN KAMI
          </span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl">Kenapa Pilih Aquila Maklon?</h2>
          <p class="mt-3 text-base-content/55">Kami berkomitmen memberikan layanan terbaik untuk brand Anda.</p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {oemOdmAdvantages.map(function(adv) {
            return (
              <div class="group relative overflow-hidden rounded-2xl border border-base-200/60 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
                <figure class="h-48 overflow-hidden">
                  <img src={adv.image} alt={adv.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
                <div class="p-6 text-center">
                  <h3 class="text-lg font-bold transition-colors duration-300 group-hover:text-primary">{adv.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-base-content/55">{adv.desc}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. CTA SECTION                                                     -->
    <!-- ================================================================== -->
    <CTASection
      title="Mulai Produksi Brand Anda Sekarang"
      description="Konsultasikan kebutuhan OEM/ODM Anda. Tim kami siap membantu dari konsep hingga produk jadi."
      buttonText="Konsultasi via WhatsApp"
      waMessage="Halo, saya ingin konsultasi layanan OEM/ODM untuk produk skincare."
    />
  </main>
</MainLayout>

<style is:global>
  .process-card {
    opacity: 0;
    transform: translateY(20px);
    animation: processReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .process-card:nth-child(1) { animation-delay: 0.05s; }
  .process-card:nth-child(2) { animation-delay: 0.1s; }
  .process-card:nth-child(3) { animation-delay: 0.15s; }
  .process-card:nth-child(4) { animation-delay: 0.2s; }
  .process-card:nth-child(5) { animation-delay: 0.25s; }
  .process-card:nth-child(6) { animation-delay: 0.3s; }
  @keyframes processReveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
