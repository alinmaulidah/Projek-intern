---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { oemOdmStats, oemInfo, oemSteps, odmInfo, odmSteps, oemOdmAdvantages } from "../data/oem-odm";
import { products } from "../data/products";
import { heroImages, factoryImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi layanan OEM/ODM.");
const waLongLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi layanan OEM/ODM untuk produk skincare. Saya tertarik dengan penjelasan di halaman OEM/ODM.");

// ─── OEM vs ODM comparison data ──────────────────────────────────────
const comparisonCards = [
  {
    mode: "OEM",
    badge: "Original Equipment Manufacturing",
    icon: "lucide:factory",
    headline: "Anda Punya Formula, Kami Produksi",
    desc: "Cocok untuk brand yang sudah memiliki formula sendiri atau ingin memilih dari katalog formula siap pakai kami.",
    points: [
      { icon: "lucide:dna", text: "Formula dari client atau pilih 200+ formula siap pakai" },
      { icon: "lucide:cog", text: "Produksi oleh pabrik — Anda fokus branding & marketing" },
      { icon: "lucide:flask-conical", text: "Full custom formulation & packaging" },
      { icon: "lucide:building-2", text: "Cocok untuk brand established & skala besar" },
    ],
    gradient: "from-primary/10 via-primary/5 to-emerald-50/50",
    borderGlow: "shadow-primary/10",
    accentBg: "bg-primary",
  },
  {
    mode: "ODM",
    badge: "Original Design Manufacturing",
    icon: "lucide:lightbulb",
    headline: "Belum Punya Formula? Kami Ciptakan",
    desc: "Solusi end-to-end untuk brand yang ingin produk eksklusif dari nol — dari konsep hingga siap jual.",
    points: [
      { icon: "lucide:microscope", text: "Formula eksklusif dikembangkan dari nol oleh tim R&D" },
      { icon: "lucide:rocket", text: "Launch lebih cepat — 30-60 hari dari brief ke sample" },
      { icon: "lucide:wallet", text: "Budget friendly — ideal untuk brand pemula & UMKM" },
      { icon: "lucide:sparkles", text: "Cocok untuk pemula yang ingin brand eksklusif" },
    ],
    gradient: "from-amber-50/80 via-secondary/5 to-secondary/10",
    borderGlow: "shadow-secondary/10",
    accentBg: "bg-secondary",
  },
];

// ─── OEM & ODM Flow timeline data ────────────────────────────────────
const oemFlow = [
  { step: 1, title: "Ide Brand", icon: "lucide:lightbulb", desc: "Anda datang dengan konsep & formula" },
  { step: 2, title: "Custom Formula", icon: "lucide:flask-conical", desc: "Tim R&D sesuaikan formula Anda" },
  { step: 3, title: "Sampling", icon: "lucide:eye", desc: "Sample dibuat & dikirim untuk review" },
  { step: 4, title: "Produksi", icon: "lucide:factory", desc: "Produksi massal dengan QC ketat" },
  { step: 5, title: "Launch!", icon: "lucide:rocket", desc: "Produk siap edar di pasaran" },
];

const odmFlow = [
  { step: 1, title: "Brief Brand", icon: "lucide:clipboard-list", desc: "Tim kami dalami visi brand Anda" },
  { step: 2, title: "Pilih Formula", icon: "lucide:search", desc: "Pilih dari katalog formula kami" },
  { step: 3, title: "Branding", icon: "lucide:paintbrush", desc: "Desain kemasan & identitas brand" },
  { step: 4, title: "Produksi", icon: "lucide:factory", desc: "Produksi + packaging sesuai standar" },
  { step: 5, title: "Launch!", icon: "lucide:rocket", desc: "Produk siap edar di pasaran" },
];

// ─── Why Choose Us ───────────────────────────────────────────────────
const whyChoose = [
  { icon: "lucide:package", title: "MOQ Fleksibel", desc: "Mulai dari 500 pcs, ideal untuk brand baru maupun established. Tidak ada minimum yang memberatkan.", color: "from-emerald-500 to-teal-600" },
  { icon: "lucide:scroll-text", title: "Support BPOM", desc: "Tim legal kami bantu urus notifikasi BPOM, pastikan produk Anda legal dan siap edar nasional.", color: "from-blue-500 to-indigo-600" },
  { icon: "lucide:badge-check", title: "Support Halal", desc: "Kami dampingi proses sertifikasi Halal — produk Anda siap menjangkau pasar yang lebih luas.", color: "from-amber-500 to-orange-600" },
  { icon: "lucide:microscope", title: "Tim R&D Expert", desc: "Lulusan farmasi & kimia berpengalaman. 2000+ bahan baku terkurasi untuk formulasi optimal.", color: "from-violet-500 to-purple-600" },
  { icon: "lucide:zap", title: "Fast Production", desc: "Lead time 30-90 hari dari sample approved hingga produk siap kirim. Tepat waktu, setiap waktu.", color: "from-rose-500 to-pink-600" },
  { icon: "lucide:shield-check", title: "QC Ketat", desc: "3 tahap quality control: bahan baku, during process, finished goods. Hanya produk lolos 100% yang dikirim.", color: "from-green-500 to-emerald-600" },
];

// ─── Product categories for ODM/OEM ──────────────────────────────────
const productCategories = [
  { name: "Skincare", icon: "lucide:droplets", count: "50+ Formula", desc: "Facial wash, toner, serum, moisturizer, sunscreen & lebih" },
  { name: "Bodycare", icon: "lucide:sparkles", count: "30+ Formula", desc: "Body lotion, body scrub, body butter, shower gel & lebih" },
  { name: "Haircare", icon: "lucide:scissors", count: "20+ Formula", desc: "Shampoo, conditioner, hair serum, hair mask & lebih" },
  { name: "Parfum", icon: "lucide:flower-2", count: "15+ Formula", desc: "EDP, EDT, body mist, solid perfume & lebih" },
  { name: "Makeup", icon: "lucide:palette", count: "25+ Formula", desc: "Lip cream, cushion, loose powder, blush & lebih" },
  { name: "Baby Care", icon: "lucide:baby", count: "10+ Formula", desc: "Baby wash, baby lotion, diaper cream & lebih" },
];

// ─── MOQ + Lead Time ─────────────────────────────────────────────────
const moqLeadData = [
  { icon: "lucide:package", title: "MOQ", value: "500 - 1.000 pcs", desc: "Minimum order quantity yang fleksibel, disesuaikan dengan jenis produk dan kebutuhan brand Anda.", color: "from-emerald-500 to-teal-500" },
  { icon: "lucide:clock", title: "Lead Time", value: "30 - 90 Hari", desc: "Estimasi produksi dari sample approved hingga produk siap kirim. Tergantung kompleksitas formula.", color: "from-amber-500 to-orange-500" },
  { icon: "lucide:file-check", title: "Legalitas", value: "BPOM + Halal", desc: "Dokumen resmi lengkap. Kami bantu urus notifikasi BPOM dan sertifikasi Halal untuk produk Anda.", color: "from-blue-500 to-indigo-500" },
];

// ─── Comparison table data ───────────────────────────────────────────
const comparisonRows = [
  { aspect: "Formula", oem: "Dari client / pilih katalog", odm: "Dikembangkan dari nol oleh R&D kami", oemIcon: "lucide:user", odmIcon: "lucide:flask-conical" },
  { aspect: "Waktu Development", oem: "14-30 hari (jika formula siap)", odm: "30-60 hari (dari brief ke sample)", oemIcon: "lucide:clock", odmIcon: "lucide:clock" },
  { aspect: "Budget", oem: "Lebih hemat — tanpa biaya R&D", odm: "Ada biaya formulasi & development", oemIcon: "lucide:wallet", odmIcon: "lucide:wallet" },
  { aspect: "Fleksibilitas", oem: "Terbatas pada formula yang ada", odm: "100% custom sesuai brief Anda", oemIcon: "lucide:settings", odmIcon: "lucide:sparkles" },
  { aspect: "Cocok Untuk", oem: "Brand established / sudah punya formula", odm: "Brand baru / ingin produk eksklusif", oemIcon: "lucide:building-2", odmIcon: "lucide:rocket" },
  { aspect: "Kepemilikan Formula", oem: "Milik client (jika bawa sendiri)", odm: "Eksklusif untuk brand Anda", oemIcon: "lucide:key", odmIcon: "lucide:crown" },
];

// ─── FAQ OEM/ODM ─────────────────────────────────────────────────────
const oemOdmFaqs = [
  { q: "Apa perbedaan utama OEM dan ODM?", a: "OEM (Original Equipment Manufacturing): Anda membawa formula sendiri atau memilih dari katalog kami, lalu kami produksikan. ODM (Original Design Manufacturing): Anda memberikan brief, tim R&D kami yang mengembangkan formula eksklusif dari nol khusus untuk brand Anda — termasuk desain kemasan dan pengurusan legalitas." },
  { q: "Berapa minimal MOQ untuk OEM dan ODM?", a: "MOQ kami fleksibel — mulai dari 500 pcs untuk produk skincare tertentu. Jumlah pastinya tergantung jenis produk, kompleksitas formula, dan packaging yang dipilih. Konsultasikan dengan tim kami untuk penawaran yang disesuaikan." },
  { q: "Bisa request formula custom sesuai keinginan?", a: "Tentu! Untuk ODM, tim R&D kami akan mengembangkan formula eksklusif berdasarkan brief Anda — dari pemilihan bahan aktif, tekstur, aroma, hingga klaim produk. Untuk OEM, Anda bisa membawa formula sendiri atau memilih dari 200+ formula siap pakai kami." },
  { q: "Apakah ada layanan white label / private label?", a: "Ya, kami juga menyediakan layanan white label — Anda bisa memilih dari produk jadi kami dan langsung memberi brand Anda sendiri. Ini opsi tercepat untuk launch produk tanpa proses formulasi." },
  { q: "Apakah dibantu pengurusan BPOM dan legalitas?", a: "Ya! Tim legal kami membantu proses notifikasi BPOM, sertifikasi Halal, dan pendaftaran HKI merek. Semua produk yang kami produksi akan didampingi sampai legalitas lengkap dan siap edar." },
  { q: "Berapa lama waktu produksi dari awal sampai jadi?", a: "Estimasi total: OEM 30-60 hari (tergantung kesiapan formula), ODM 60-90 hari (termasuk formulasi & sampling). Timeline detail akan kami berikan setelah konsultasi awal sesuai kebutuhan spesifik brand Anda." },
];
---

<MainLayout
  title="OEM / ODM | Aquila Maklon"
  description="Layanan OEM dan ODM maklon skincare & kosmetik. Produksi brand Anda dengan standar kualitas premium — dari konsep hingga produk siap jual."
>
  <main class="overflow-hidden">
    <!-- ================================================================== -->
    <!-- 1. HERO — Split layout: text left, visual right                    -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-base-100 via-primary/[0.02] to-emerald-50/30 pt-20 pb-6 lg:pt-28 lg:pb-10">
      <!-- Decorative blurs -->
      <div class="pointer-events-none absolute -left-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-20 top-20 h-[400px] w-[400px] rounded-full bg-secondary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute bottom-0 left-1/3 h-[300px] w-[300px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <!-- LEFT: Text content -->
          <div class="reveal text-center lg:text-left">
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5">
              <span class="h-2 w-2 rounded-full bg-primary animate-pulse"></span>
              <span class="text-[11px] font-semibold tracking-[0.2em] text-primary">OEM & ODM MAKLON</span>
            </div>
            <h1 class="text-3xl font-black tracking-tight md:text-4xl lg:text-5xl lg:leading-tight">
              Solusi <span class="text-primary">OEM & ODM</span> untuk Brand Skincare Anda
            </h1>
            <p class="mt-4 leading-relaxed text-base-content/55 md:text-lg max-w-lg mx-auto lg:mx-0">
              Kami membantu Anda membangun brand skincare dari nol hingga siap jual — dengan dukungan formula, produksi, legalitas, dan packaging dalam satu atap.
            </p>

            <!-- CTA buttons -->
            <div class="mt-7 flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
              <a href={waLink} target="_blank" rel="noopener noreferrer"
                class="inline-flex h-13 items-center gap-2 rounded-xl bg-primary px-7 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-primary/25">
                <Icon name="mdi:whatsapp" size={18} />
                Konsultasi Gratis
                <Icon name="lucide:arrow-right" size={16} />
              </a>
              <a href="#comparison"
                class="inline-flex h-13 items-center gap-2 rounded-xl border-2 border-base-300 bg-white px-7 text-sm font-semibold text-base-content transition-all duration-300 hover:border-primary/30 hover:text-primary hover:shadow-md">
                <Icon name="lucide:arrow-down" size={16} />
                Pelajari Perbedaannya
              </a>
            </div>

            <!-- Floating mini stats -->
            <div class="mt-8 flex flex-wrap items-center gap-3 justify-center lg:justify-start">
              {oemOdmStats.slice(0, 3).map((stat) => (
                <div class="flex items-center gap-2 rounded-xl border border-base-200 bg-white/80 px-3 py-2 shadow-sm backdrop-blur-sm">
                  <span class="text-lg font-black text-primary">{stat.value}</span>
                  <span class="text-[11px] font-medium text-base-content/50 leading-tight max-w-[100px]">{stat.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- RIGHT: Visual / Animated product mockup -->
          <div class="reveal relative">
            <!-- Main image card -->
            <div class="relative z-10 overflow-hidden rounded-3xl shadow-2xl shadow-primary/10">
              <img
                src={heroImages.skincareProduction}
                alt="OEM ODM Skincare Manufacturing"
                class="h-[280px] w-full object-cover lg:h-[420px]"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/40 via-transparent to-transparent"></div>
            </div>

            <!-- Decorative gradient blob behind image -->
            <div class="absolute -right-10 -top-10 z-0 h-[200px] w-[200px] rounded-full bg-gradient-to-br from-primary/15 to-emerald-200/20 blur-2xl lg:h-[300px] lg:w-[300px]"></div>
            <div class="absolute -bottom-8 -left-8 z-0 h-[180px] w-[180px] rounded-full bg-gradient-to-br from-secondary/10 to-amber-100/20 blur-2xl lg:h-[250px] lg:w-[250px]"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. OEM VS ODM — 2 premium glass cards side-by-side                 -->
    <!-- ================================================================== -->
    <section id="comparison" class="relative overflow-hidden bg-base-200/50 py-20 lg:py-28">
      <div class="pointer-events-none absolute -left-40 top-0 h-[400px] w-[400px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-40 bottom-0 h-[400px] w-[400px] rounded-full bg-secondary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-white/80 px-5 py-2 shadow-sm backdrop-blur-sm">
            <Icon name="lucide:git-compare" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">PERBANDINGAN</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">OEM vs ODM — Pilih yang Tepat</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Pahami perbedaan keduanya untuk menentukan layanan yang paling sesuai dengan kebutuhan brand Anda.
          </p>
        </div>

        <div class="mt-14 grid gap-8 lg:grid-cols-2 lg:gap-10">
          {comparisonCards.map((card) => (
            <div class={`reveal group relative overflow-hidden rounded-3xl border border-base-200 bg-gradient-to-br ${card.gradient} p-8 shadow-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl ${card.borderGlow} lg:p-10`}>
              {/* Glass shine effect */}
              <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/40 blur-3xl transition-all duration-700 group-hover:scale-150 group-hover:bg-white/50"></div>

              <div class="relative">
                {/* Header */}
                <div class="flex items-center gap-4">
                  <div class={`flex h-14 w-14 items-center justify-center rounded-2xl ${card.accentBg} shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl`}>
                    <Icon name={card.icon} size={26} class="text-white" />
                  </div>
                  <div>
                    <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-base-content/40">{card.badge}</span>
                    <h3 class="text-2xl font-black text-base-content">{card.mode}</h3>
                  </div>
                </div>

                <p class="mt-4 text-sm font-bold text-base-content/80 md:text-base">{card.headline}</p>
                <p class="mt-2 text-sm leading-relaxed text-base-content/55">{card.desc}</p>

                {/* Points */}
                <div class="mt-6 space-y-3">
                  {card.points.map((p) => (
                    <div class="flex items-start gap-3 rounded-xl bg-white/50 px-4 py-3 backdrop-blur-sm transition-all duration-300 hover:bg-white/80 hover:shadow-sm">
                      <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                        <Icon name={p.icon} size={13} class="text-primary" />
                      </div>
                      <p class="text-sm leading-relaxed text-base-content/65">{p.text}</p>
                    </div>
                  ))}
                </div>

                {/* Action link */}
                <div class="mt-7">
                  <a href={waLink} target="_blank" rel="noopener noreferrer"
                    class={`inline-flex h-11 items-center gap-2 rounded-xl ${card.accentBg} px-5 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl`}>
                    <Icon name="mdi:whatsapp" size={16} />
                    Konsultasi {card.mode}
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. OEM & ODM VISUAL DETAIL — Split image+text sections              -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-100 py-20 lg:py-28">
      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <!-- OEM Detail -->
        <div class="reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16 mb-20">
          <!-- Image -->
          <div class="relative order-last lg:order-first">
            <div class="relative z-10 overflow-hidden rounded-3xl shadow-xl shadow-primary/10">
              <img
                src={oemInfo.image}
                alt={oemInfo.imageAlt}
                class="h-[300px] w-full object-cover lg:h-[380px]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/30 via-transparent to-transparent"></div>
            </div>
            <div class="absolute -left-6 -top-6 z-0 h-[180px] w-[180px] rounded-full bg-primary/[0.08] blur-2xl"></div>
            <div class="absolute -bottom-6 -right-6 z-0 h-[160px] w-[160px] rounded-full bg-emerald-100/40 blur-2xl"></div>
          </div>

          <!-- Text -->
          <div class="order-first lg:order-last">
            <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 mb-4">
              <Icon name="lucide:factory" size={14} class="text-primary" />
              <span class="text-[11px] font-semibold tracking-[0.2em] text-primary">OEM</span>
            </div>
            <h2 class="text-2xl font-black md:text-3xl tracking-tight">{oemInfo.title}</h2>
            <p class="mt-1 text-base font-bold text-primary/80">{oemInfo.subtitle}</p>
            <p class="mt-4 leading-relaxed text-base-content/55 md:text-lg">{oemInfo.description}</p>
            <div class="mt-6 space-y-3">
              {oemInfo.highlights.map((h) => (
                <div class="flex items-start gap-3 rounded-xl bg-primary/[0.04] px-4 py-3">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                    <Icon name={h.icon} size={13} class="text-primary" />
                  </div>
                  <p class="text-sm leading-relaxed text-base-content/65">{h.text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- ODM Detail -->
        <div class="reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <!-- Text -->
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-secondary/20 bg-secondary/5 px-4 py-1.5 mb-4">
              <Icon name="lucide:lightbulb" size={14} class="text-secondary" />
              <span class="text-[11px] font-semibold tracking-[0.2em] text-secondary">ODM</span>
            </div>
            <h2 class="text-2xl font-black md:text-3xl tracking-tight">{odmInfo.title}</h2>
            <p class="mt-1 text-base font-bold text-secondary/80">{odmInfo.subtitle}</p>
            <p class="mt-4 leading-relaxed text-base-content/55 md:text-lg">{odmInfo.description}</p>
            <div class="mt-6 space-y-3">
              {odmInfo.highlights.map((h) => (
                <div class="flex items-start gap-3 rounded-xl bg-secondary/[0.04] px-4 py-3">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-secondary/10">
                    <Icon name={h.icon} size={13} class="text-secondary" />
                  </div>
                  <p class="text-sm leading-relaxed text-base-content/65">{h.text}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Image -->
          <div class="relative">
            <div class="relative z-10 overflow-hidden rounded-3xl shadow-xl shadow-secondary/10">
              <img
                src={odmInfo.image}
                alt={odmInfo.imageAlt}
                class="h-[300px] w-full object-cover lg:h-[380px]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-secondary/30 via-transparent to-transparent"></div>
            </div>
            <div class="absolute -right-6 -top-6 z-0 h-[180px] w-[180px] rounded-full bg-secondary/[0.08] blur-2xl"></div>
            <div class="absolute -bottom-6 -left-6 z-0 h-[160px] w-[160px] rounded-full bg-amber-100/40 blur-2xl"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. FLOW DIAGRAM — OEM & ODM timeline                               -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-100 py-20 lg:py-28">
      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-primary/20 bg-primary/5 px-5 py-2">
            <Icon name="lucide:git-branch" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">ALUR KERJA</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Bagaimana Prosesnya?</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Dua jalur berbeda — satu tujuan: produk berkualitas siap edar dengan brand Anda.
          </p>
        </div>

        <div class="mt-16 grid gap-12 lg:grid-cols-2 lg:gap-10">
          {/* OEM Flow */}
