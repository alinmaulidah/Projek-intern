---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { visionMission, ourStory, trustPlaceholder } from "../data/company";
import { advantages } from "../data/advantages";
import { factoryHighlights } from "../data/factory";
import { factoryImages, avatarImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

// Gallery data for lab/factory photos
const galleryItems = [
  { icon: "lucide:flask-conical", label: "Laboratorium Riset", desc: "Tim R&D mengembangkan formula inovatif", image: factoryImages.formulasiLab },
  { icon: "lucide:factory", label: "Area Produksi", desc: "Fasilitas produksi standar CPKB", image: factoryImages.productionLine },
  { icon: "lucide:microscope", label: "Quality Control", desc: "Pengujian produk sebelum dikirim", image: factoryImages.qualityControl },
  { icon: "lucide:droplets", label: "Sampling Room", desc: "Ruang pembuatan sample produk", image: factoryImages.samplingRoom },
  { icon: "lucide:package", label: "Packaging Area", desc: "Area pengemasan produk jadi", image: factoryImages.packagingArea },
  { icon: "lucide:test-tubes", label: "Formulasi Lab", desc: "Laboratorium formulasi skincare", image: factoryImages.formulasiLab },
];
---

<MainLayout
  title="Tentang Kami | Aquila Maklon"
  description="Pelajari lebih lanjut tentang perusahaan jasa maklon skincare dan kosmetik terpercaya."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. HERO — Company Profile Premium Minimal                         -->
    <!-- ================================================================== -->
    <section class="relative flex min-h-[85vh] items-center overflow-hidden bg-gradient-to-b from-base-100 via-primary/[0.02] to-base-100">
      <!-- Subtle ambient light -->
      <div class="pointer-events-none absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-primary/5 blur-[120px]"></div>
      <div class="pointer-events-none absolute -bottom-40 right-0 h-[400px] w-[400px] rounded-full bg-secondary/[0.04] blur-[100px]"></div>

      <div class="relative mx-auto w-full max-w-7xl px-4 py-28 lg:px-8">
        <div class="grid items-center gap-16 lg:grid-cols-5 lg:gap-20">
          <!-- Left: Text — col-span-3 -->
          <div class="lg:col-span-3">
            <!-- Subtle label -->
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/[0.04] px-4 py-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              <span class="text-[11px] font-semibold tracking-[0.2em] text-primary">TENTANG KAMI</span>
            </div>

            <h1 class="text-[clamp(2.25rem,5vw,4rem)] font-black leading-[1.08] tracking-tight text-base-content">
              Mitra Maklon<br />
              <span class="text-primary">Skincare & Kosmetik</span><br />
              Terpercaya di Indonesia
            </h1>

            <p class="mt-6 max-w-2xl text-base leading-relaxed text-base-content/60 md:text-lg">
              {siteConfig.description}
            </p>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-base-content/50">
              Berdiri sejak 2015, kami telah membantu 200+ brand lokal dan internasional mewujudkan produk kecantikan mereka — dari konsep, formulasi, produksi, hingga legalitas dan distribusi.
            </p>

            <!-- CTA -->
            <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
              <a
                href={waLink}
                target="_blank" rel="noopener noreferrer"
                class="group inline-flex h-13 items-center gap-2.5 rounded-xl bg-primary px-7 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition-all duration-300 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5"
              >
                <span class="flex h-6 w-6 items-center justify-center rounded-lg bg-white/15">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </span>
                Konsultasi Sekarang
              </a>
              <a
                href="#visi-misi"
                class="group inline-flex h-13 items-center gap-2 rounded-xl border border-base-300 bg-base-100 px-7 text-sm font-medium text-base-content/70 transition-all duration-300 hover:border-primary/30 hover:text-primary hover:-translate-y-0.5"
              >
                Visi & Misi
                <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>

            <!-- Stats -->
            <div class="mt-12 flex flex-wrap gap-x-12 gap-y-4">
              <div>
                <p class="text-3xl font-black text-primary">10+</p>
                <p class="mt-0.5 text-xs font-medium text-base-content/45">Tahun Pengalaman</p>
              </div>
              <div>
                <p class="text-3xl font-black text-primary">200+</p>
                <p class="mt-0.5 text-xs font-medium text-base-content/45">Brand Partner Aktif</p>
              </div>
              <div>
                <p class="text-3xl font-black text-primary">500+</p>
                <p class="mt-0.5 text-xs font-medium text-base-content/45">Produk Berhasil Dipasarkan</p>
              </div>
            </div>
          </div>

          <!-- Right: Photo collage — col-span-2 -->
          <div class="lg:col-span-2">
            <div class="relative grid grid-cols-2 gap-3">
              <!-- Main large image -->
              <div class="col-span-2 overflow-hidden rounded-2xl shadow-xl">
                <img
                  src={factoryImages.productionLine}
                  alt="Produksi Aquila Maklon"
                  class="h-56 w-full object-cover md:h-72"
                />
              </div>
              <!-- Bottom left -->
              <div class="overflow-hidden rounded-2xl shadow-lg">
                <img
                  src={factoryImages.labResearch}
                  alt="Laboratorium Riset"
                  class="h-40 w-full object-cover"
                />
              </div>
              <!-- Bottom right -->
              <div class="relative overflow-hidden rounded-2xl shadow-lg">
                <img
                  src={factoryImages.qualityControl}
                  alt="Quality Control"
                  class="h-40 w-full object-cover"
                />
                <!-- Overlay badge -->
                <div class="absolute bottom-3 left-3 rounded-lg bg-white/95 px-3 py-1.5 shadow-lg">
                  <p class="text-[11px] font-bold text-primary">CPKB Certified</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. VISI & MISI                                                     -->
    <!-- ================================================================== -->
    <section id="visi-misi" class="relative overflow-hidden bg-base-100 py-20">
      <div class="pointer-events-none absolute -right-60 -top-60 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-60 -bottom-60 h-[400px] w-[400px] rounded-full bg-secondary/10 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Visi & Misi</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Komitmen Kami</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Visi dan misi yang menjadi landasan setiap langkah kami dalam melayani brand partner.
          </p>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-2">
          <!-- Vision -->
          <div class="group card rounded-3xl border border-primary/20 bg-gradient-to-br from-primary/5 to-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-primary/5">
            <div class="card-body flex h-full flex-col p-8 md:p-10">
              <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 text-3xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/30 group-hover:to-secondary/30">
                <Icon name="lucide:telescope" size={32} />
              </div>
              <h3 class="card-title text-2xl md:text-3xl">Visi</h3>
              <div class="mt-4 flex-1">
                <p class="text-base leading-relaxed text-base-content/75 md:text-lg">
                  "{visionMission.vision}"
                </p>
              </div>
              <div class="mt-auto border-t border-primary/10 pt-5">
                <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary">Fokus Kami</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kualitas Produk</span>
                  <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kemitraan Terpercaya</span>
                  <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Inovasi Formula</span>
                  <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kepuasan Brand</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Mission -->
          <div class="group card rounded-3xl border border-secondary/20 bg-gradient-to-br from-secondary/5 to-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-secondary/5">
            <div class="card-body flex h-full flex-col p-8 md:p-10">
              <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 text-3xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/30 group-hover:to-secondary/30">
                <Icon name="lucide:target" size={32} />
              </div>
              <h3 class="card-title text-2xl md:text-3xl">Misi</h3>
              <ul class="mt-4 flex-1 space-y-4">
                {visionMission.missions.map((m, i) => (
                  <li class="flex items-start gap-4 group/item transition-all duration-300 hover:translate-x-1">
                    <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary to-secondary text-xs font-bold text-white shadow-md transition-all duration-300 group-hover/item:scale-110">
                      {i + 1}
                    </span>
                    <span class="text-base text-base-content/75 md:text-lg">{m}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. OWNER CARD — Story / Founder Quote                              -->
    <!-- ================================================================== -->
    <section class="relative bg-gradient-to-r from-primary to-secondary py-20">
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 50% 50%, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-white/5 blur-3xl"></div>

      <div class="relative mx-auto max-w-5xl px-4 lg:px-8">
        <div class="mx-auto max-w-4xl">
          <div class="rounded-3xl bg-white/10 p-1 backdrop-blur-sm shadow-2xl">
            <div class="rounded-[calc(1.5rem-4px)] bg-white/10 p-8 md:p-12">
              <div class="flex flex-col items-center gap-8 md:flex-row md:items-start">
                <!-- Owner Avatar -->
                <div class="shrink-0">
                  <div class="mx-auto h-28 w-28 overflow-hidden rounded-full ring-4 ring-white/20 md:h-36 md:w-36">
                    <img src={avatarImages.founder} alt="Founder Aquila Maklon" class="h-full w-full object-cover" />
                  </div>
                  <div class="mt-3 text-center">
                    <p class="text-sm font-bold text-white">Founder</p>
                    <p class="text-xs text-white/60">Aquila Maklon</p>
                  </div>
                </div>

                <!-- Quote & Story -->
                <div class="flex-1 text-center md:text-left">
                  <svg class="mx-auto mb-4 h-8 w-8 text-white/30 md:mx-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                  <h3 class="text-2xl font-black text-white md:text-3xl">{ourStory.title}</h3>
                  <div class="mt-4 space-y-4">
                    {ourStory.paragraphs.map((p) => (
                      <p class="text-base leading-relaxed text-white/80 md:text-lg">{p}</p>
                    ))}
                  </div>
                  <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:items-center md:justify-start">
                    <div class="flex -space-x-2">
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-sm font-bold text-white ring-2 ring-white/30"><Icon name="lucide:flask-conical" size={18} class="text-white" /></div>
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-sm font-bold text-white ring-2 ring-white/30"><Icon name="lucide:factory" size={18} class="text-white" /></div>
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-sm font-bold text-white ring-2 ring-white/30"><Icon name="lucide:package" size={18} class="text-white" /></div>
                    </div>
                    <p class="text-sm text-white/60">Berkolaborasi dengan tim ahli di bidangnya</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. KEUNGGULAN PERUSAHAAN (Advantages)                             -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Keunggulan</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Mengapa Memilih Aquila Maklon?</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Kami hadir dengan berbagai keunggulan yang membuat proses maklon Anda menjadi mudah dan profesional.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {advantages.map((adv) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 overflow-hidden">
              {adv.image && (
                <figure class="h-40 overflow-hidden">
                  <img src={adv.image} alt={adv.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
              )}
              <div class="card-body items-center text-center p-8">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-4xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  <Icon name={adv.icon} size={40} />
                </div>
                <h3 class="card-title mt-4 text-xl">{adv.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-base-content/70">{adv.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. GALLERY LAB — Animated sliding cards                            -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/50 py-20">
      <div class="pointer-events-none absolute -right-60 -bottom-60 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Galeri Fasilitas</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Sekilas Fasilitas & Lab Kami</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Fasilitas produksi modern dengan standar CPKB untuk hasil terbaik bagi brand Anda.
          </p>
        </div>

        <!-- Scrolling row 1 (left to right) -->
        <div class="mt-14 overflow-hidden">
          <div class="flex animate-scroll-left gap-5" style="--scroll-speed: 30s;">
            {[...galleryItems, ...galleryItems].map((item) => (
              <div class="group w-72 shrink-0 overflow-hidden rounded-2xl border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
                <figure class="h-40 overflow-hidden">
                  <img src={item.image} alt={item.label} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
                <div class="p-5">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 text-lg transition-all duration-500 group-hover:scale-110">
                      <Icon name={item.icon} size={20} />
                    </div>
                    <div>
                      <h4 class="font-bold text-base-content">{item.label}</h4>
                      <p class="text-sm text-base-content/60">{item.desc}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Scrolling row 2 (right to left, offset) -->
        <div class="mt-6 overflow-hidden">
          <div class="flex animate-scroll-right gap-5" style="--scroll-speed: 35s;">
            {[...galleryItems, ...galleryItems].reverse().map((item) => (
              <div class="group w-72 shrink-0 overflow-hidden rounded-2xl border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
                <figure class="h-40 overflow-hidden">
                  <img src={item.image} alt={item.label} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
                <div class="p-5">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 text-lg transition-all duration-500 group-hover:scale-110">
                      <Icon name={item.icon} size={20} />
                    </div>
                    <div>
                      <h4 class="font-bold text-base-content">{item.label}</h4>
                      <p class="text-sm text-base-content/60">{item.desc}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 6. FACTORY HIGHLIGHTS — Card kecil animasi bergeser                -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Fasilitas</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Fasilitas & Layanan Pabrik</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Didukung fasilitas lengkap dan tim profesional untuk hasil produksi terbaik.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {factoryHighlights.map((item) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 overflow-hidden">
              {item.image && (
                <figure class="h-40 overflow-hidden">
                  <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
              )}
              <div class="card-body items-center text-center p-8">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-4xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  <Icon name={item.icon} size={40} />
                </div>
                <h3 class="card-title mt-4 text-xl">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-base-content/70">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 7. TRUST PLACEHOLDER — Company values                              -->
    <!-- ================================================================== -->
    <section class="bg-base-200/50 py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Nilai Perusahaan</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Nilai-Nilai yang Kami Pegang</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Prinsip yang menjadi fondasi dalam setiap pelayanan kami kepada brand partner.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-3">
          {trustPlaceholder.map((item) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 overflow-hidden">
              {item.image && (
                <figure class="h-40 overflow-hidden">
                  <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                </figure>
              )}
              <div class="card-body items-center text-center p-8">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-4xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  <Icon name={item.icon} size={40} />
                </div>
                <h3 class="card-title mt-4 text-xl">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-base-content/70">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 8. CTA BANNER Premium                                             -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 50% 50%, white 1px, transparent 1px); background-size: 50px 50px;"></div>

      <div class="relative mx-auto max-w-5xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm animate-bounce">
          <Icon name="lucide:handshake" size={48} class="text-white" />
        </div>

        <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl leading-tight">
          Kenali Kami Lebih Lanjut
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg text-white/75 md:text-xl leading-relaxed">
          Hubungi kami untuk konsultasi gratis dan mulai perjalanan brand Anda bersama Aquila Maklon. Tim kami siap mendampingi dari awal hingga produk siap jual!
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href={waLink}
            target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="mr-2"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Konsultasi via WhatsApp
          </a>
          <a
            href="/layanan"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white/30 bg-white/10 px-10 text-base text-white backdrop-blur-sm transition-all duration-300 hover:border-white/50 hover:bg-white/20"
          >
            Lihat Layanan Kami
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-white/60">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Gratis Konsultasi
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Tanpa Biaya Tersembunyi
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Pendampingan Penuh
          </span>
        </div>
      </div>
    </section>
  </main>
