---
import MainLayout from "../layouts/MainLayout.astro";
import CTASection from "../components/sections/CTASection.astro";
import { blogPosts, blogCategories } from "../data/blog";
import Icon from "../components/ui/Icon.astro";
---

<MainLayout
  title="Blog | Aquila Magna"
  description="Baca artikel dan panduan seputar bisnis maklon skincare, kosmetik, tips branding, dan tren terkini."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. PAGE HEADER                                                     -->
    <!-- ================================================================== -->
   

    <!-- ================================================================== -->
    <!-- 2. FILTER KATEGORI                                                 -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 pt-12 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <button class="category-filter btn btn-sm rounded-full btn-primary text-white" data-category="all">
          Semua
        </button>
        {blogCategories.map((cat) => (
          <button class="category-filter btn btn-sm rounded-full btn-soft btn-primary" data-category={cat}>
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. GRID ARTIKEL BLOG                                               -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
      <div id="blog-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {blogPosts.map((post) => (
          <article class="blog-card group card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20" data-category={post.category}>
            <!-- Image -->
            <figure class="h-48 overflow-hidden rounded-t-2xl">
              <img
                src={post.image}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
            </figure>

            <div class="card-body">
              <!-- Meta -->
              <div class="flex items-center gap-3 text-xs text-base-content/50">
                <span class="badge badge-soft badge-primary badge-sm">{post.category}</span>
                <span>{post.date}</span>
                <span>•</span>
                <span>{post.readTime}</span>
              </div>

              <!-- Title -->
              <h3 class="card-title mt-2 text-lg transition-colors duration-300 group-hover:text-primary">
                {post.title}
              </h3>

              <!-- Excerpt -->
              <p class="text-sm leading-relaxed text-base-content/70">
                {post.excerpt}
              </p>

              <!-- Tags -->
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="badge badge-soft badge-ghost badge-sm text-xs">{tag}</span>
                ))}
              </div>

              <!-- Read More -->
              <div class="card-actions mt-4">
                <a href={`/blog/${post.slug}`} class="btn btn-outline btn-primary btn-sm rounded-full group/btn">
                  Baca Selengkapnya
                  <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-1" />
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. CTA SECTION                                                     -->
    <!-- ================================================================== -->
    <CTASection
      title="Ingin Konsultasi Langsung?"
      description="Punya pertanyaan seputar bisnis maklon? Tim kami siap membantu Anda melalui WhatsApp."
      buttonText="Konsultasi via WhatsApp"
    />
  </main>
</MainLayout>

<script>
  // Filter blog posts by category
  const filters = document.querySelectorAll<HTMLElement>(".category-filter");
  const cards = document.querySelectorAll<HTMLElement>(".blog-card");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      // Update button active state
      filters.forEach((b) => {
        b.classList.remove("btn-primary", "text-white");
        b.classList.add("btn-soft");
      });
      btn.classList.remove("btn-soft");
      btn.classList.add("btn-primary", "text-white");

      // Filter cards
      cards.forEach((card) => {
        if (category === "all" || card.dataset.category === category) {
          card.style.display = "";
          // Animate
          card.style.opacity = "0";
          card.style.transform = "translateY(10px)";
          requestAnimationFrame(() => {
            card.style.transition = "opacity 0.3s ease, transform 0.3s ease";
            card.style.opacity = "1";
            card.style.transform = "translateY(0)";
          });
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>
