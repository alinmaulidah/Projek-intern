<script>
  // ═══════════════════════════════════════════════════════════════════════
  // IntersectionObserver — staggered reveal for all animated elements
  // ═══════════════════════════════════════════════════════════════════════
  const observerOptions = { threshold: 0.15, rootMargin: "0px 0px -40px 0px" };

  const reveal = (entries, obs) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const siblings = Array.from(el.parentElement?.children || []);
        const realIdx = siblings.indexOf(el);
        el.style.transition = `all 0.55s cubic-bezier(0.16, 1, 0.3, 1) ${realIdx * 0.07}s`;
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        obs.unobserve(el);
      }
    });
  };

  const observer = new IntersectionObserver(reveal, observerOptions);

  // Observe all animated elements
  document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
  document.querySelectorAll(".cap-card").forEach(el => observer.observe(el));
  document.querySelectorAll(".workflow-step").forEach(el => observer.observe(el));
  document.querySelectorAll(".workflow-step-mobile").forEach(el => observer.observe(el));
  document.querySelectorAll(".stat-card").forEach(el => observer.observe(el));
</script>
