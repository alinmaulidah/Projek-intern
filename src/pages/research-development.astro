---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { rdStats, rdPhases, rdFacilities, rdInnovations } from "../data/research-development";
import { heroImages, factoryImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi dengan tim R&D untuk pengembangan formula skincare.");
const waLongLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya tertarik dengan layanan R&D Aquila Maklon. Saya ingin konsultasi tentang pengembangan formula eksklusif untuk brand saya.");

// ═══════════════════════════════════════════════════════════════════════
// R&D Capabilities — 6 premium glass cards
// ═══════════════════════════════════════════════════════════════════════
const rdCapabilities = [
  {
    icon: "lucide:trending-up",
    title: "Market Research",
    subtitle: "Analisis Tren & Pasar",
    desc: "Riset pasar mendalam — analisis tren global, preferensi konsumen, dan gap kompetitor. Fondasi data-driven untuk formulasi produk yang tepat sasaran.",
    color: "from-indigo-500 to-blue-600",
    glow: "shadow-indigo-500/10",
  },
  {
    icon: "lucide:flask-conical",
    title: "Formula Development",
    subtitle: "Pengembangan Formula",
    desc: "Tim formulator menyusun formula berdasarkan brief brand Anda. Pemilihan bahan aktif, konsentrasi, dan teknologi penghantaran disesuaikan target klaim.",
    color: "from-emerald-500 to-teal-600",
    glow: "shadow-emerald-500/10",
  },
  {
    icon: "lucide:thermometer",
    title: "Stability Testing",
    subtitle: "Uji Stabilitas Produk",
    desc: "Accelerated stability test pada multi suhu — 40°C, 50°C, dan cycling. Parameter pH, viskositas, warna, bau, dan homogenitas dipantau selama 3 bulan.",
    color: "from-amber-500 to-orange-600",
    glow: "shadow-amber-500/10",
  },
  {
    icon: "lucide:heart-pulse",
    title: "Compatibility Testing",
    subtitle: "Uji Kompatibilitas",
    desc: "Uji patch pada panel terlatih untuk memastikan toleransi kulit. Evaluasi iritasi, sensitivitas, dan reaksi alergi sesuai protokol dermatologi standar.",
    color: "from-rose-500 to-pink-600",
    glow: "shadow-rose-500/10",
  },
  {
    icon: "lucide:beaker",
    title: "Sample Development",
    subtitle: "Pembuatan Sample",
    desc: "Prototype dibuat dalam skala lab melalui beberapa iterasi. Setiap iterasi didokumentasikan dalam batch record untuk traceability dan konsistensi.",
    color: "from-violet-500 to-purple-600",
    glow: "shadow-violet-500/10",
  },
  {
    icon: "lucide:sparkles",
    title: "Formula Optimization",
    subtitle: "Optimasi Formula",
    desc: "Formula disempurnakan berdasarkan hasil uji — dari tekstur, aroma, hingga efikasi. Scale-up bertahap memastikan konsistensi di volume produksi besar.",
    color: "from-cyan-500 to-teal-600",
    glow: "shadow-cyan-500/10",
  },
];

// ═══════════════════════════════════════════════════════════════════════
// R&D Workflow — Interactive timeline
// ═══════════════════════════════════════════════════════════════════════
const rdWorkflow = [
  { step: 1, title: "Idea & Brief", icon: "lucide:lightbulb", desc: "Anda sampaikan visi produk — kami tangkap dalam brief teknis yang komprehensif." },
  { step: 2, title: "Research", icon: "lucide:search", desc: "Riset pasar, analisis tren, dan studi bahan aktif untuk fondasi formula." },
  { step: 3, title: "Formula Dev", icon: "lucide:flask-conical", desc: "Pengembangan formula dengan pemilihan bahan aktif dan teknologi penghantaran." },
  { step: 4, title: "Lab Testing", icon: "lucide:thermometer", desc: "Uji stabilitas, mikrobio, kompatibilitas kulit, dan efektivitas di laboratorium." },
  { step: 5, title: "Sample", icon: "lucide:beaker", desc: "Sample dibuat dan dikirim ke Anda untuk evaluasi — revisi hingga 100% puas." },
  { step: 6, title: "Optimization", icon: "lucide:sparkles", desc: "Formula difinalisasi dan di-scale-up untuk memastikan konsistensi produksi." },
  { step: 7, title: "Production Ready", icon: "lucide:rocket", desc: "Formula siap diproduksi massal — lengkap dengan dokumentasi dan batch record." },
];

// ═══════════════════════════════════════════════════════════════════════
// Ingredients — Chip cards
// ═══════════════════════════════════════════════════════════════════════
const ingredients = [
  { name: "Niacinamide", tag: "Brightening", desc: "Vitamin B3 — mencerahkan, memperkuat skin barrier, dan mengurangi hiperpigmentasi." },
  { name: "Hyaluronic Acid", tag: "Hydration", desc: "Melembapkan intensif — mampu menahan air 1000x berat molekulnya untuk kulit plump & glowing." },
  { name: "Retinol", tag: "Anti-Aging", desc: "Vitamin A — mempercepat regenerasi sel, mengurangi garis halus, dan memperbaiki tekstur kulit." },
  { name: "Ceramide", tag: "Barrier Repair", desc: "Memperbaiki skin barrier — mencegah dehidrasi dan melindungi kulit dari iritasi eksternal." },
  { name: "Centella Asiatica", tag: "Soothing", desc: "CICA — menenangkan kulit sensitif, meredakan kemerahan, dan mempercepat penyembuhan." },
  { name: "AHA / BHA / PHA", tag: "Exfoliation", desc: "Eksfoliasi kimia — mengangkat sel kulit mati, membersihkan pori, dan meratakan tekstur." },
];

// ═══════════════════════════════════════════════════════════════════════
// Stats — Metric cards
// ═══════════════════════════════════════════════════════════════════════
const rdMetricStats = [
  { value: "500+", label: "Formula Dikembangkan", icon: "lucide:flask-conical", color: "from-emerald-500 to-teal-600" },
  { value: "50+", label: "Active Ingredients", icon: "lucide:droplets", color: "from-blue-500 to-indigo-600" },
  { value: "1000+", label: "Samples Dikembangkan", icon: "lucide:beaker", color: "from-violet-500 to-purple-600" },
  { value: "10+", label: "Tahun Pengalaman", icon: "lucide:badge-check", color: "from-amber-500 to-orange-600" },
];

// ═══════════════════════════════════════════════════════════════════════
// Comparison table — Aquila Magna vs Typical Maklon
// ═══════════════════════════════════════════════════════════════════════
const comparisonRows = [
  { aspect: "Custom Formula", aquila: "100% eksklusif — dikembangkan dari nol sesuai brief brand", typical: "Formula template terbatas — pilih dari katalog yang ada", aquilaIcon: "lucide:crown", typicalIcon: "lucide:copy" },
  { aspect: "Trend Research", aquila: "Riset pasar & tren global — data-driven formulation", typical: "Mengikuti tren umum — tanpa analisis pasar mendalam", aquilaIcon: "lucide:trending-up", typicalIcon: "lucide:activity" },
  { aspect: "Stability Testing", aquila: "3 bulan uji stabilitas dipercepat — multi suhu & cycling test", typical: "Uji stabilitas minimal — sering hanya uji organoleptik", aquilaIcon: "lucide:thermometer", typicalIcon: "lucide:thermometer-sun" },
  { aspect: "Active Optimization", aquila: "Optimasi konsentrasi & delivery system — enkapsulasi liposom", typical: "Formulasi standar — tanpa optimasi bahan aktif spesifik", aquilaIcon: "lucide:sparkles", typicalIcon: "lucide:settings" },
];
---

<MainLayout
  title="Research & Development | Aquila Maklon"
  description="Research & Development skincare & kosmetik. Tim R&D profesional siap mengembangkan formula inovatif & eksklusif untuk brand Anda."
>
  <main class="overflow-hidden">
    <!-- ================================================================== -->
    <!-- 1. HERO MINI — Split layout: text left, visual right               -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-base-100 via-primary/[0.02] to-emerald-50/30 pt-20 pb-6 lg:pt-28 lg:pb-10">
      <!-- Decorative blurs & molecule-like shapes -->
      <div class="pointer-events-none absolute -left-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute right-10 top-1/3 h-4 w-4 rounded-full bg-primary/20 blur-[2px] animate-pulse"></div>
      <div class="pointer-events-none absolute right-20 top-1/4 h-3 w-3 rounded-full bg-secondary/20 blur-[2px]"></div>
      <div class="pointer-events-none absolute right-32 bottom-1/3 h-5 w-5 rounded-full bg-primary/15 blur-[2px]"></div>
      <div class="pointer-events-none absolute right-16 bottom-1/4 h-3 w-3 rounded-full bg-emerald-300/30 blur-[2px]"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <!-- LEFT: Text content -->
          <div class="reveal text-center lg:text-left">
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5">
              <Icon name="lucide:flask-conical" size={14} class="text-primary" />
              <span class="text-[11px] font-semibold tracking-[0.2em] text-primary">RESEARCH & DEVELOPMENT</span>
            </div>
            <h1 class="text-3xl font-black tracking-tight md:text-4xl lg:text-5xl lg:leading-tight">
              Research &<br /><span class="text-primary">Development</span> Excellence
            </h1>
            <p class="mt-4 leading-relaxed text-base-content/55 md:text-lg max-w-lg mx-auto lg:mx-0">
              Tim R&D kami mengembangkan formula skincare inovatif berdasarkan riset bahan aktif, tren pasar, dan kebutuhan brand Anda — di laboratorium modern berstandar CPKB.
            </p>

            <!-- CTA buttons -->
            <div class="mt-7 flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
              <a href={waLink} target="_blank" rel="noopener noreferrer"
                class="inline-flex h-13 items-center gap-2 rounded-xl bg-primary px-7 text-sm font-bold text-white shadow-lg shadow-primary/15 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-primary/20">
                <Icon name="mdi:whatsapp" size={18} />
                Konsultasi dengan Tim R&D
                <Icon name="lucide:arrow-right" size={16} />
              </a>
              <a href="#capabilities"
                class="inline-flex h-13 items-center gap-2 rounded-xl border-2 border-base-300 bg-white px-7 text-sm font-semibold text-base-content transition-all duration-300 hover:border-primary/30 hover:text-primary hover:shadow-md">
                <Icon name="lucide:arrow-down" size={16} />
                Lihat Kapabilitas
              </a>
            </div>
          </div>

          <!-- RIGHT: Scientific visual -->
          <div class="reveal relative hidden lg:block">
            <!-- Main lab image card -->
            <div class="relative z-10 overflow-hidden rounded-3xl shadow-2xl shadow-primary/10">
              <img
                src={heroImages.labResearch}
                alt="R&D Laboratory — Research & Development Skincare"
                class="h-[420px] w-full object-cover"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/40 via-transparent to-transparent"></div>

              {/* Floating science badge */}
              <div class="absolute left-5 top-5 rounded-xl border border-white/30 bg-white/75 backdrop-blur-md px-4 py-2.5 shadow-lg">
                <div class="flex items-center gap-2">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary">
                    <Icon name="lucide:microscope" size={15} class="text-white" />
                  </div>
                  <div>
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-base-content/50">Laboratorium</p>
                    <p class="text-xs font-bold text-base-content">CPKB Certified</p>
                  </div>
                </div>
              </div>
            </div>

            {/* Decorative gradient blobs */}
            <div class="absolute -right-10 -top-10 z-0 h-[300px] w-[300px] rounded-full bg-gradient-to-br from-primary/15 to-emerald-200/20 blur-2xl"></div>
            <div class="absolute -bottom-8 -left-8 z-0 h-[250px] w-[250px] rounded-full bg-gradient-to-br from-secondary/10 to-amber-100/20 blur-2xl"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. R&D CAPABILITIES — 6 premium glass cards                        -->
    <!-- ================================================================== -->
    <section id="capabilities" class="relative overflow-hidden bg-base-200/50 py-20 lg:py-28">
      <div class="pointer-events-none absolute -left-40 top-0 h-[400px] w-[400px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-40 bottom-0 h-[400px] w-[400px] rounded-full bg-secondary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-white/80 px-5 py-2 shadow-sm backdrop-blur-sm">
            <Icon name="lucide:sparkles" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">KAPABILITAS R&D</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Kemampuan Riset & Pengembangan</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Dari riset pasar hingga optimasi formula — semuanya dilakukan oleh tim ahli di laboratorium modern.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rdCapabilities.map((cap) => (
            <div class={`cap-card group relative overflow-hidden rounded-2xl border border-base-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl ${cap.glow} lg:p-7`} style="opacity:0;transform:translateY(30px)">
              {/* Glass shine */}
              <div class="pointer-events-none absolute -right-10 -top-10 h-32 w-32 rounded-full bg-white/40 blur-2xl transition-all duration-700 group-hover:scale-150 group-hover:bg-white/50"></div>

              <div class="relative">
                {/* Icon with soft glow */}
                <div class={`mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${cap.color} text-white shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl`}>
                  <Icon name={cap.icon} size={26} />
                </div>

                <span class="text-[10px] font-semibold uppercase tracking-[0.25em] text-primary/60">{cap.subtitle}</span>
                <h3 class="mt-1 text-lg font-bold text-base-content">{cap.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-base-content/55">{cap.desc}</p>

                {/* Animated underline */}
                <div class="mt-5 h-0.5 w-0 rounded-full bg-gradient-to-r from-primary to-primary/60 transition-all duration-700 group-hover:w-16"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. R&D WORKFLOW — Interactive timeline                              -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-100 py-20 lg:py-28">
      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-primary/20 bg-primary/5 px-5 py-2">
            <Icon name="lucide:git-branch" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">WORKFLOW R&D</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Alur Pengembangan Formula</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Proses terstruktur dari ide hingga formula siap produksi — transparan dan terukur.
          </p>
        </div>

        {/* Desktop: Horizontal timeline */}
        <div class="mt-16 hidden lg:block">
          <div class="relative">
            {/* Timeline line */}
            <div class="absolute left-8 right-8 top-8 h-0.5 bg-gradient-to-r from-primary/10 via-primary/30 to-primary/10"></div>

            <div class="relative z-10 grid grid-cols-7 gap-2">
              {rdWorkflow.map((w, i) => (
                <div class={`workflow-step group flex flex-col items-center text-center`} style="opacity:0;transform:translateY(20px)">
                  {/* Step circle */}
                  <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-primary/20 bg-white text-lg font-black text-primary shadow-md transition-all duration-400 group-hover:border-primary group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:scale-110">
                    {w.step}
                  </div>

                  {/* Icon */}
                  <div class="mt-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/5 transition-all duration-400 group-hover:bg-primary/15">
                    <Icon name={w.icon} size={17} class="text-primary" />
                  </div>

                  {/* Title */}
                  <p class="mt-2 text-xs font-bold text-base-content/80 leading-tight">{w.title}</p>

                  {/* Arrow down indicator (except last) */}
                  {i < rdWorkflow.length - 1 && (
                    <div class="mt-1 text-primary/20 transition-colors duration-400 group-hover:text-primary/40">
                      <Icon name="lucide:chevron-down" size={12} />
                    </div>
                  )}
                </div>
              ))}
            </div>

            {/* Description row (shown on hover via JS) — simplified: compact text below */}
            <div class="mt-6 grid grid-cols-7 gap-2">
              {rdWorkflow.map((w) => (
                <p class="text-center text-[10px] leading-relaxed text-base-content/35">{w.desc}</p>
              ))}
            </div>
          </div>
        </div>

        {/* Mobile: Vertical timeline */}
        <div class="mt-14 lg:hidden">
          <div class="relative">
            {/* Vertical line */}
            <div class="absolute left-[27px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary/20 via-primary/10 to-primary/5"></div>

            <div class="space-y-6">
              {rdWorkflow.map((w, i) => (
                <div class="workflow-step-mobile group relative flex gap-5" style="opacity:0;transform:translateY(20px)">
                  {/* Step circle on the line */}
                  <div class="relative z-10 flex h-[54px] w-[54px] shrink-0 items-center justify-center rounded-full border-2 border-primary/20 bg-white text-lg font-black text-primary shadow-md transition-all duration-400 group-hover:border-primary group-hover:bg-primary group-hover:text-white group-hover:shadow-lg">
                    {w.step}
                  </div>

                  {/* Content */}
                  <div class="pt-1">
                    <div class="flex items-center gap-2">
                      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/5">
                        <Icon name={w.icon} size={15} class="text-primary" />
                      </div>
                      <h4 class="text-sm font-bold text-base-content">{w.title}</h4>
                    </div>
                    <p class="mt-1.5 text-sm leading-relaxed text-base-content/50">{w.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. INGREDIENT INNOVATION — Premium chip cards                      -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/50 py-20 lg:py-28">
      <div class="pointer-events-none absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-white/80 px-5 py-2 shadow-sm backdrop-blur-sm">
            <Icon name="lucide:droplets" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">BAHAN AKTIF</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Ingredient Innovation</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Bahan aktif premium terkurasi untuk formulasi yang aman, efektif, dan sesuai tren terkini.
          </p>
        </div>

        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {ingredients.map((ing) => (
            <div class="ingredient-card group relative overflow-hidden rounded-2xl border border-base-200 bg-white p-6 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl">
              {/* Subtle gradient overlay on hover */}
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/[0.02] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

              <div class="relative">
                {/* Tag chip */}
                <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-[10px] font-semibold tracking-[0.15em] text-primary">
                  {ing.tag}
                </span>

                <h3 class="mt-3 text-lg font-bold text-base-content">{ing.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-base-content/50">{ing.desc}</p>

                {/* Decorative molecule dots */}
                <div class="mt-5 flex gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-primary/30"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-primary/50"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-primary/60"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-primary/20"></span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. R&D STATS — Premium metric cards with counter                   -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary to-emerald-900 py-20 lg:py-28">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-white/[0.05] blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-20 h-[300px] w-[300px] rounded-full bg-white/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/[0.06] px-5 py-2 backdrop-blur-sm">
            <Icon name="lucide:bar-chart-3" size={16} class="text-white/70" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-white/60">R&D BY THE NUMBERS</span>
          </div>
          <h2 class="mt-5 text-3xl font-black text-white md:text-4xl tracking-tight">Terbukti oleh Data</h2>
          <p class="mt-3 max-w-xl text-white/50 md:text-lg">
            Angka berbicara — komitmen kami terhadap riset dan inovasi tercermin dari pencapaian berikut.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {rdMetricStats.map((stat) => (
            <div class="stat-card group relative overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.04] p-6 text-center backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:border-white/[0.15] hover:bg-white/[0.07] lg:p-8" style="opacity:0;transform:translateY(20px)">

              {/* Value */}
              <div class="text-4xl font-black text-white md:text-5xl">{stat.value}</div>
