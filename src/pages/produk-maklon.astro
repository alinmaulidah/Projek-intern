---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import CTASection from "../components/sections/CTASection.astro";
import Icon from "../components/ui/Icon.astro";
import { products } from "../data/products";

const categories = [
  ...new Set(products.map((p) => p.category)),
];
---

<MainLayout
  title="Produk Maklon | Aquila Maklon"
  description="Berbagai produk yang bisa dibuat melalui jasa maklon, dari skincare hingga kosmetik."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. PAGE HEADER                                                     -->
    <!-- ================================================================== -->
    <PageHeader
      title="Produk yang Bisa Dibuat"
      description="Berbagai kategori produk maklon tersedia, dari skincare, bodycare, haircare, hingga kosmetik. Semua bisa disesuaikan dengan kebutuhan brand Anda."
      badge="Produk"
      breadcrumb="Produk Maklon"
    />

    <!-- Grid Semua Produk -->
    <section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {products.map((p) => (
          <div class="flex items-start gap-4 rounded-2xl border border-base-200 bg-base-100 p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-xl text-primary"><Icon name={p.icon} size={24} /></div>
            <div>
              <h4 class="font-bold">{p.name}</h4>
              <p class="mt-1 text-sm text-base-content/60">{p.desc}</p>
              <span class="badge badge-soft badge-primary mt-2 text-xs">{p.category}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Kategori Produk -->
    <section class="bg-base-200/50 py-16">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="text-center mb-12">
          <p class="mb-3 font-semibold tracking-wide text-primary">Kategori</p>
          <h2 class="text-3xl font-black md:text-4xl">Kategori Produk Maklon</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {categories.map((cat) => {
            const catProducts = products.filter((p) => p.category === cat);
            return (
              <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                <div class="card-body p-6">
                  <h3 class="card-title text-xl">{cat}</h3>
                  <ul class="mt-3 space-y-2">
                    {catProducts.map((cp) => (
                      <li class="flex items-center gap-2 text-sm text-base-content/70">
                        <Icon name={cp.icon} size={18} />
                        <span>{cp.name}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. CTA SECTION                                                     -->
    <!-- ================================================================== -->
    <CTASection
      title="Tertarik dengan Produk Tertentu?"
      description="Konsultasikan dengan tim kami untuk mengetahui produk apa yang paling cocok untuk brand Anda."
      buttonText="Konsultasi via WhatsApp"
      waMessage="Halo, saya tertarik dengan produk maklon. Bisakah saya konsultasi?"
    />
  </main>
</MainLayout>