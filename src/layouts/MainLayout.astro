---
import "../styles/global.css";
import { siteConfig } from "../data/site";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWA from "../components/FloatingWA.astro";
import { AstroFont } from "astro-font";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aquila Maklon",
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="id" data-theme="maklon-theme">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:image" content="/assets/Logo.svg" />
    <meta property="og:image:width" content="562" />
    <meta property="og:image:height" content="158" />
    <AstroFont
      config={[
        {
          name: "Arsenal",
          src: [],
          googleFontsURL: "https://fonts.googleapis.com/css2?family=Arsenal:wght@400;700&display=swap",
          preload: true,
          display: "swap",
          selector: "h1, h2, h3, h4, h5, h6",
          fallback: "sans-serif",
          cssVariable: "font-heading",
        },
        {
          name: "Karla",
          src: [],
          googleFontsURL: "https://fonts.googleapis.com/css2?family=Karla:wght@300;400;600;700;800&display=swap",
          preload: true,
          display: "swap",
          selector: "body",
          fallback: "sans-serif",
          cssVariable: "font-body",
        },
        {
          name: "Josefin Slab",
          src: [],
          googleFontsURL: "https://fonts.googleapis.com/css2?family=Josefin+Slab:wght@300;400;600;700&display=swap",
          preload: true,
          display: "swap",
          selector: ".small-text",
          fallback: "serif",
          cssVariable: "font-small",
        },
      ]}
    />
  </head>
  <body>
    <Navbar />
    <FloatingWA />
    <slot />
    <Footer />
  </body>
</html>