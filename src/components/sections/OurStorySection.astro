---
import Icon from "../ui/Icon.astro";
import { ourStory } from "../../data/company";
---

<section id="cerita" class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <!-- Left: Text -->
      <div>
        <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">
          {ourStory.badge}
        </span>
        <h2 class="text-3xl font-black md:text-4xl">{ourStory.title}</h2>
        {ourStory.paragraphs.map((paragraph) => (
          <p class="mt-4 leading-relaxed text-base-content/70">{paragraph}</p>
        ))}
      </div>

      <!-- Right: Photo Card -->
      <div class="relative">
        <div class="overflow-hidden rounded-3xl shadow-xl">
          <img src={ourStory.image} alt="Our team at Aquila Magna" class="h-full w-full object-cover aspect-[4/3]" />
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-6">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                <Icon name="lucide:flask-conical" size={20} class="text-white" />
              </div>
              <p class="text-sm font-semibold text-white">Dari Lab ke Pasar — Bersama Aquila Magna</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
