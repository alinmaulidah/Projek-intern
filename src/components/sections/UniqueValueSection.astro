---
import Icon from "../ui/Icon.astro";
import { siteConfig } from "../../data/site";
import { advantages } from "../../data/advantages";
import { createWhatsappLink } from "../../lib/whatsapp";

const waLink = createWhatsappLink(
  siteConfig.waNumber,
  siteConfig.waText
);
---

<section id="keunikan" class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid items-start gap-12 md:grid-cols-2">
      <!-- Left: Text -->
      <div>
        <p class="mb-3 font-semibold tracking-wide text-primary">Keunikan Perusahaan</p>
        <h2 class="text-3xl font-black md:text-4xl">
          Kenapa Harus Memilih Kami?
        </h2>
        <p class="mt-6 leading-relaxed text-base-content/70">
          Kami tidak hanya memproduksi produk, tapi mendampingi Anda dari nol hingga 
          produk siap dipasarkan. Dengan pengalaman dan tim profesional, setiap tahapan 
          maklon dirancang agar mudah, transparan, dan berkualitas.
        </p>
        <p class="mt-4 leading-relaxed text-base-content/70">
          Dari pendampingan ide, formulasi custom, desain kemasan profesional, hingga 
          pengurusan legalitas BPOM dan Halal — semua bisa Anda dapatkan dalam satu tempat.
        </p>
        <a
          href={waLink}
          target="_blank" rel="noopener noreferrer"
          class="btn btn-primary mt-6 rounded-full px-6 text-white shadow-md transition-all duration-300 hover:shadow-lg"
        >
          Konsultasi Sekarang
        </a>
      </div>

      <!-- Right: Advantage Cards -->
      <div class="grid gap-4 sm:grid-cols-2">
        {advantages.slice(0, 4).map((item) => (
          <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
            <div class="card-body p-5">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl text-primary">
                <Icon name={item.icon} size={24} />
              </div>
              <h3 class="card-title mt-2 text-base">{item.title}</h3>
              <p class="text-sm text-base-content/70">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
