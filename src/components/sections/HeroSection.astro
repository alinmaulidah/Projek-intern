---
import Icon from "../ui/Icon.astro";
import { siteConfig } from "../../data/site";
import { createWhatsappLink } from "../../lib/whatsapp";
import { heroImages } from "../../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

const slides = [
  {
    gradient: "from-emerald-900/90 via-primary/85 to-emerald-800/80",
    image: heroImages.skincareHero,
    badge: "Partner Maklon Profesional",
    badgeIcon: "lucide:sparkles",
    title: "Wujudkan Brand Skincare & Kosmetik Sendiri",
    desc: "Kami membantu proses maklon dari konsultasi, formulasi, produksi, legalitas, hingga produk siap jual.",
  },
  {
    gradient: "from-emerald-900/90 via-primary/85 to-emerald-800/80",
    image: heroImages.formulasiHero,
    badge: "Formula Custom & Inovatif",
    badgeIcon: "lucide:microscope",
    title: "Riset & Formulasi oleh Tim Ahli",
    desc: "Tim R&D berpengalaman menciptakan formula eksklusif sesuai tren pasar dan kebutuhan brand Anda.",
  },
  {
    gradient: "from-sky-900/90 via-primary/85 to-teal-800/80",
    image: heroImages.packagingReady,
    badge: "Legalitas & Produksi Terjamin",
    badgeIcon: "lucide:package",
    title: "BPOM, Halal, & Siap Jual",
    desc: "Produk Anda diurus legalitasnya dari BPOM, sertifikat Halal, hingga HKI. Tinggal jual!",
  },
];
---

<section id="hero" class="relative flex h-[85vh] min-h-[500px] items-center overflow-hidden">
  {slides.map((slide, idx) => (
    <div class="absolute inset-0 transition-opacity duration-1000 ease-in-out" id={`hero-slide-${idx}`}>
      <!-- Background Image -->
      <img src={slide.image} alt="" class="absolute inset-0 h-full w-full object-cover scale-110" id={`hero-bg-${idx}`} />
      <!-- Gradient Overlay -->
      <div class={`absolute inset-0 bg-gradient-to-br ${slide.gradient}`}></div>
      <!-- Pattern -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>
  ))}

  <!-- Decorative Blobs -->
  <div class="pointer-events-none absolute -right-32 -top-32 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-32 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-24 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Badge -->
      <span class="inline-flex items-center gap-1.5 animate-fade-in-down rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-semibold tracking-widest text-white/90 backdrop-blur-sm" id="hero-badge">
        <Icon name="lucide:sparkles" size={14} class="text-white/80" />
        Partner Maklon Profesional
      </span>

      <!-- Title -->
      <h1 class="mt-6 animate-fade-in-up text-4xl font-black leading-tight text-white md:text-6xl lg:text-7xl" id="hero-title">
        Wujudkan Brand Skincare & Kosmetik Sendiri
      </h1>

      <!-- Description -->
      <p class="mx-auto mt-6 max-w-3xl animate-fade-in-up text-lg leading-relaxed text-white/80 md:text-xl" id="hero-desc" style="animation-delay: 0.1s">
        Kami membantu proses maklon dari konsultasi, formulasi, produksi, legalitas, hingga produk siap jual.
      </p>

      <!-- Buttons -->
      <div class="mt-10 flex animate-fade-in-up flex-col items-center justify-center gap-4 sm:flex-row" style="animation-delay: 0.2s">
        <a
          href={waLink}
          target="_blank" rel="noopener noreferrer"
          class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl"
        >
          <Icon name="mdi:whatsapp" class="mr-2 h-5 w-5" />
          Konsultasi via WhatsApp
        </a>
        <a
          href="/alur-maklon"
          class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white/30 bg-white/10 px-10 text-base text-white backdrop-blur-sm transition-all duration-300 hover:border-white/50 hover:bg-white/20"
        >
          Lihat Alur Maklon
        </a>
      </div>

      <!-- Trust Badges -->
      <div class="mt-12 flex animate-fade-in-up flex-wrap items-center justify-center gap-6" style="animation-delay: 0.3s">
        <div class="flex items-center gap-2 text-white/70">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-medium">BPOM Terdaftar</span>
        </div>
        <div class="flex items-center gap-2 text-white/70">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-medium">Sertifikat Halal</span>
        </div>
        <div class="flex items-center gap-2 text-white/70">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-medium">CPKB Standard</span>
        </div>
        <div class="flex items-center gap-2 text-white/70">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-medium">ISO 9001:2015</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Slide Indicators -->
  <div class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-3">
    {slides.map((_, idx) => (
      <button
        class="h-2 rounded-full transition-all duration-500"
        class:list={{
          "w-8 bg-white": true,
          "w-2 bg-white/40": false,
        }}
        id={`hero-dot-${idx}`}
        aria-label={`Slide ${idx + 1}`}
      ></button>
    ))}
  </div>
</section>

<style is:global>
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes zoomIn {
    from { transform: scale(1.1); }
    to { transform: scale(1); }
  }
  .animate-fade-in-down {
    animation: fadeInDown 0.6s ease-out forwards;
  }
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }
  #hero-slide-0 { z-index: 1; }
  #hero-slide-1,
  #hero-slide-2 { z-index: 0; }
  #hero-bg-0,
  #hero-bg-1,
  #hero-bg-2 {
    animation: zoomIn 6s ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-down,
    .animate-fade-in-up { animation: none; opacity: 1; }
    #hero-bg-0, #hero-bg-1, #hero-bg-2 { animation: none; }
  }
</style>

<script>
  // Hero Slider
  const slidesCount = 3;
  let current = 0;

  const badge = document.getElementById("hero-badge");
  const title = document.getElementById("hero-title");
  const desc = document.getElementById("hero-desc");

  const slideData = [
    {
      badge: "Partner Maklon Profesional",
      title: "Wujudkan Brand Skincare & Kosmetik Sendiri",
      desc: "Kami membantu proses maklon dari konsultasi, formulasi, produksi, legalitas, hingga produk siap jual.",
    },
    {
      badge: "Formula Custom & Inovatif",
      title: "Riset & Formulasi oleh Tim Ahli",
      desc: "Tim R&D berpengalaman menciptakan formula eksklusif sesuai tren pasar dan kebutuhan brand Anda.",
    },
    {
      badge: "Legalitas & Produksi Terjamin",
      title: "BPOM, Halal, & Siap Jual",
      desc: "Produk Anda diurus legalitasnya dari BPOM, sertifikat Halal, hingga HKI. Tinggal jual!",
    },
  ];

  function goToSlide(idx: number) {
    // Hide all slides
    for (let i = 0; i < slidesCount; i++) {
      const slide = document.getElementById(`hero-slide-${i}`);
      const dot = document.getElementById(`hero-dot-${i}`);
      if (slide) slide.style.opacity = "0";
      if (dot) {
        dot.style.width = "0.5rem";
        dot.style.backgroundColor = "rgba(255,255,255,0.4)";
      }
    }

    // Show current slide
    const activeSlide = document.getElementById(`hero-slide-${idx}`);
    const activeDot = document.getElementById(`hero-dot-${idx}`);
    if (activeSlide) {
      activeSlide.style.zIndex = "1";
      activeSlide.style.opacity = "1";
    }
    if (activeDot) {
      activeDot.style.width = "2rem";
      activeDot.style.backgroundColor = "white";
    }
    // Push to back after showing
    for (let i = 0; i < slidesCount; i++) {
      if (i !== idx) {
        const s = document.getElementById(`hero-slide-${i}`);
        if (s) s.style.zIndex = "0";
      }
    }

    // Update text
    if (badge) badge.textContent = slideData[idx].badge;
    if (title) {
      title.style.opacity = "0";
      title.style.transform = "translateY(24px)";
      setTimeout(() => {
        title.textContent = slideData[idx].title;
        title.style.opacity = "1";
        title.style.transform = "translateY(0)";
      }, 150);
    }
    if (desc) {
      desc.style.opacity = "0";
      desc.style.transform = "translateY(24px)";
      setTimeout(() => {
        desc.textContent = slideData[idx].desc;
        desc.style.opacity = "1";
        desc.style.transform = "translateY(0)";
      }, 250);
    }

    current = idx;
  }

  // Auto-slide every 5 seconds
  setInterval(() => {
    const next = (current + 1) % slidesCount;
    goToSlide(next);
  }, 5000);

  // Click dots to navigate
  document.querySelectorAll("[id^='hero-dot-']").forEach((dot) => {
    dot.addEventListener("click", () => {
      const idx = parseInt(dot.id.replace("hero-dot-", ""));
      goToSlide(idx);
    });
  });
</script>