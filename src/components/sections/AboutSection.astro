---
import Icon from "../ui/Icon.astro";
import { siteConfig } from "../../data/site";
import { testimonials } from "../../data/testimonials";
import { createWhatsappLink } from "../../lib/whatsapp";

const waLink = createWhatsappLink(
  siteConfig.waNumber,
  siteConfig.waText
);
---

<section id="tentang" class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <div>
        <p class="mb-3 font-semibold tracking-wide text-primary">Tentang Kami</p>
        <h2 class="text-3xl font-black md:text-4xl">
          Mitra Maklon Terpercaya untuk Brand Kecantikan Anda
        </h2>
        <p class="mt-6 text-base-content/70 leading-relaxed">
          {siteConfig.description} Dengan pengalaman bertahun-tahun, kami telah membantu 
          ratusan brand owner mewujudkan produk kecantikan impian mereka.
        </p>
        <p class="mt-4 text-base-content/70 leading-relaxed">
          Dari konsep hingga produk siap jual, kami dampingi setiap prosesnya. 
          Tim profesional kami siap membantu Anda di setiap tahap.
        </p>
        <a
          href={waLink}
          target="_blank" rel="noopener noreferrer"
          class="btn btn-primary mt-6 rounded-full px-6 text-white shadow-md"
        >
          Konsultasi Sekarang
        </a>
      </div>

      {/* Testimonials */}
      <div class="space-y-4">
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-base-content/50">
          Testimoni Brand Partner
        </p>
        {testimonials.slice(0, 3).map((item) => (
          <div class="card border border-base-200 bg-base-100 shadow-sm">
            <div class="card-body p-5">
              <div class="flex items-center gap-2">
                {[...Array(item.rating)].map(() => (
                  <span class="text-yellow-400 text-sm"><Icon name="lucide:star" size={14} class="text-yellow-400" /></span>
                ))}
              </div>
              <p class="mt-2 text-sm italic text-base-content/70">"{item.text}"</p>
              <div class="mt-3">
                <p class="text-sm font-semibold">{item.name}</p>
                <p class="text-xs text-primary">{item.brand}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>