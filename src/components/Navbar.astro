---
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { navItems } from "../data/nav";
import Icon from "./ui/Icon.astro";

const currentPath = Astro.url.pathname;
const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

function isActivePath(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

function isChildActive(children: { href: string }[] | undefined): boolean {
  if (!children) return false;
  return children.some((child) => currentPath.startsWith(child.href));
}
---

<header class="sticky top-0 z-50 border-b border-base-300/40 bg-white/90 backdrop-blur-2xl transition-all duration-300">
  <div class="navbar mx-auto max-w-7xl px-4 lg:px-8">
    <!-- ================================================================== -->
    <!-- KIRI: LOGO ICON                                                    -->
    <!-- ================================================================== -->
    <div class="navbar-start">
      <a href="/" class="group flex items-center transition-all duration-500 hover:opacity-90" aria-label="Aquila Magna">
        <img src="/assets/Logo.svg" alt="Aquila Magna" class="h-7 w-auto sm:h-8" />
      </a>
    </div>
    <!-- ================================================================== -->
    <!-- TENGAH: DESKTOP NAV MENU                                           -->
    <!-- ================================================================== -->
    <div class="navbar-center hidden lg:flex">
      <nav class="flex items-center gap-0.5">
        {navItems.map((item) => {
          if (item.children) {
            const hasActiveChild = isChildActive(item.children);
            return (
              <div class="dropdown dropdown-hover relative">
                <a
                  role="button"
                  class={`group relative flex cursor-pointer items-center gap-1 rounded-full px-4 py-2 text-sm font-semibold tracking-wide transition-all duration-300 ${
                    hasActiveChild
                      ? "text-primary"
                      : "text-base-content/70 hover:text-primary"
                  }`}
                >
                  {hasActiveChild && (
                    <span class="absolute inset-0 rounded-full bg-primary/8"></span>
                  )}
                  <span class="relative z-10">{item.label}</span>
                  <Icon
                    name="chevron-down"
                    class={`relative z-10 h-3 w-3 transition-transform duration-300 ${hasActiveChild ? "rotate-180" : ""}`}
                  />
                </a>

                <!-- Dropdown -->
                <ul class="dropdown-content menu-vertical invisible absolute -left-4 top-full mt-2 w-72 gap-0.5 rounded-2xl border border-base-200/80 bg-white p-2 opacity-0 shadow-xl shadow-black/5 transition-all duration-300 [.dropdown:hover_&]:visible [.dropdown:hover_&]:opacity-100">
                  {item.children.map((child) => {
                    const childActive = isActivePath(child.href);
                    return (
                      <li>
                        <a
                          href={child.href}
                          class={`group flex items-start gap-3 rounded-xl px-4 py-3 transition-all duration-200 ${
                            childActive
                              ? "bg-primary/10 text-primary"
                              : "text-base-content/70 hover:bg-primary/5 hover:text-primary"
                          }`}
                        >
                          {child.icon && (
                            <div class={`mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ${
                              childActive
                                ? "bg-primary/15 text-primary"
                                : "bg-base-200/60 text-base-content/50 group-hover:bg-primary/10 group-hover:text-primary"
                            } transition-all duration-200`}>
                              <Icon name={child.icon} class="h-4 w-4" />
                            </div>
                          )}
                          <div class="flex flex-col items-start">
                            <span class="flex items-center gap-2 text-sm font-semibold transition-colors">
                              {childActive && (
                                <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                              )}
                              {child.label}
                            </span>
                            {child.description && (
                              <span class="mt-0.5 text-[11px] font-normal leading-snug text-base-content/40 transition-colors group-hover:text-base-content/60">
                                {child.description}
                              </span>
                            )}
                          </div>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          }

          const active = isActivePath(item.href!);
          return (
            <a
              href={item.href}
              class={`group relative rounded-full px-4 py-2 text-sm font-semibold tracking-wide transition-all duration-300 ${
                active
                  ? "text-primary"
                  : "text-base-content/70 hover:text-primary"
              }`}
            >
              {active && (
                <span class="absolute inset-0 rounded-full bg-primary/8"></span>
              )}
              <span class="relative z-10">{item.label}</span>
              {active && (
                <span class="absolute -bottom-px left-1/2 h-0.5 w-5 -translate-x-1/2 rounded-full bg-primary"></span>
              )}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- ================================================================== -->
    <!-- KANAN: DESKTOP CTA + MOBILE HAMBURGER                              -->
    <!-- ================================================================== -->
    <div class="navbar-end flex items-center gap-2">
      <!-- Desktop CTA -->
      <a
        href={waLink}
        target="_blank" rel="noopener noreferrer"
        class="btn hidden h-10 rounded-full border-none bg-primary px-5 text-sm font-semibold text-white shadow-md transition-all duration-300 hover:brightness-110 hover:shadow-lg hover:scale-105 md:inline-flex"
      >
        <Icon name="mdi:whatsapp" class="mr-1.5 h-4 w-4" />
        Konsultasi Gratis
      </a>

      <!-- Hamburger Mobile -->
      <div class="dropdown dropdown-end lg:hidden">
        <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Buka menu">
          <Icon name="menu" class="h-5 w-5 text-base-content/70" />
        </div>

        <!-- Mobile Menu Dropdown - Full Width -->
        <ul tabindex="0" class="menu menu-sm dropdown-content z-50 mx-0 mt-1 w-screen gap-0.5 rounded-none border-x-0 border-t border-base-200 bg-white px-4 pb-6 pt-16 shadow-xl shadow-black/10" style="position:fixed;left:0;right:0;top:60px">
          {navItems.map((item) => {
            if (item.children) {
              const hasActiveChild = isChildActive(item.children);
              return (
                <li>
                  <details open={hasActiveChild}>
                    <summary class={`rounded-xl px-4 py-2.5 ${hasActiveChild ? "font-semibold text-primary" : "font-medium text-base-content/80"}`}>
                      <span class="text-sm">{item.label}</span>
                      <Icon name="chevron-down" class="h-3 w-3 opacity-50" />
                    </summary>
                    <ul class="ml-2 border-l-2 border-primary/15 bg-base-200/30 rounded-xl p-2">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class={`flex items-start gap-3 rounded-xl px-4 py-2.5 transition-all duration-200 ${isActivePath(child.href) ? "bg-primary/10 font-semibold text-primary" : "text-base-content/70 hover:bg-primary/5 hover:text-primary"}`}
                          >
                            {child.icon && (
                              <div class={`mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg ${
                                isActivePath(child.href)
                                  ? "bg-primary/15 text-primary"
                                  : "bg-base-200/60 text-base-content/50"
                              } transition-all duration-200`}>
                                <Icon name={child.icon} class="h-3.5 w-3.5" />
                              </div>
                            )}
                            <div>
                              <span class="text-sm font-semibold">{child.label}</span>
                              {child.description && (
                                <span class="mt-0.5 block text-xs font-normal text-base-content/40">{child.description}</span>
                              )}
                            </div>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              );
            }
            const active = isActivePath(item.href!);
            return (
              <li>
                <a
                  href={item.href}
                  class={`rounded-xl px-4 py-2.5 transition-all duration-200 ${active ? "bg-primary/10 font-semibold text-primary" : "text-base-content/70 hover:bg-primary/5 hover:text-primary"}`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </div>
</header>
